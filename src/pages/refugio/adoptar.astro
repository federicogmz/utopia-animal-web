---
import Layout from '../../layouts/Layout.astro';

const inputClass = "w-full rounded-xl border border-gray-200 bg-white px-4 py-3 text-sm text-gray-900 placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-elim-400 focus:border-elim-400 transition";
const labelClass = "block text-sm font-semibold text-gray-800 mb-2";
const helpClass = "block text-xs text-gray-500 mt-1";
const sectionTitleClass = "text-2xl sm:text-3xl font-extrabold text-gray-900 mb-2";
const sectionDescClass = "text-gray-500 mb-8";

const compromisos = [
  'Esterilizar al gato cuando esté en edad',
  'Brindar atención veterinaria de por vida',
  'No abandonar ni regalar al gato sin notificar a Elim',
  'Permitir visita de seguimiento si Elim la solicita',
  'Mantener al gato en espacio seguro con mallas o protección',
];
---

<Layout
  title="Quiero adoptar · Elim Refugio Animal"
  description="Postúlate para adoptar un gato con Elim Refugio Animal. Llena el formulario de adopción responsable y nuestro equipo revisará tu solicitud."
  brand="elim"
>

  <!-- ── HERO ───────────────────────────────────────────── -->
  <section class="bg-gradient-to-br from-elim-950 via-elim-900 to-gray-950 pt-24 pb-0 relative overflow-hidden">
    <div class="absolute top-0 left-0 w-80 h-80 bg-elim-400 opacity-10 rounded-full blur-3xl -translate-x-1/2 -translate-y-1/2"></div>
    <div class="max-w-4xl mx-auto px-4 sm:px-6 relative pb-16">
      <div class="inline-flex items-center gap-2 bg-white/10 border border-white/20 text-white/80 text-xs font-semibold px-4 py-2 rounded-full mb-6">
        <span class="w-1.5 h-1.5 bg-elim-300 rounded-full animate-pulse"></span>
        Adopción responsable · Elim Refugio
      </div>
      <h1 class="text-4xl sm:text-5xl font-extrabold text-white leading-tight mb-5">
        Quiero adoptar<br/><span class="text-elim-400">un gato de Elim</span>
      </h1>
      <p class="text-elim-200 text-lg leading-relaxed max-w-2xl">
        Adoptar es un compromiso de por vida. Este formulario nos ayuda a entender tu hogar y tu motivación, para encontrar el match perfecto entre tú y un gato de nuestra red.
      </p>
    </div>
    <div class="relative -mb-px">
      <svg viewBox="0 0 1440 50" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full">
        <path d="M0 50L1440 50L1440 0Q720 50 0 0Z" fill="white"/>
      </svg>
    </div>
  </section>

  <!-- ── FORMULARIO ────────────────────────────────────── -->
  <section class="bg-white py-16 sm:py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">

      <!-- ERROR BANNER -->
      <div id="errorBanner" class="hidden mb-6 bg-red-50 border border-red-200 text-red-800 rounded-xl px-5 py-4 text-sm">
        <strong>Algo salió mal.</strong> <span id="errorMsg">Por favor intenta de nuevo en unos minutos.</span>
      </div>

      <form id="adoptForm" class="space-y-8" novalidate>

        <!-- PROGRESS BAR -->
        <div>
          <div class="flex items-center justify-between mb-3 text-xs font-semibold text-gray-500">
            <span id="stepLabel">Paso 1 de 6 · Datos personales</span>
            <span id="stepCount">1 / 6</span>
          </div>
          <div class="w-full h-2 bg-elim-50 rounded-full overflow-hidden">
            <div id="progressBar" class="h-full bg-elim-500 transition-all duration-300" style="width: 16.66%"></div>
          </div>
        </div>

        <!-- Honeypot -->
        <input type="text" name="_website" id="_website" tabindex="-1" autocomplete="off" style="position:absolute;left:-9999px" aria-hidden="true" />

        <!-- ── STEP 1: Datos personales ───────────────── -->
        <fieldset data-step="1" class="space-y-6">
          <div>
            <p class="text-xs font-bold text-elim-600 uppercase tracking-widest mb-2">Paso 1</p>
            <h2 class={sectionTitleClass}>Datos personales</h2>
            <p class={sectionDescClass}>Empecemos por conocerte. Esta información es confidencial y solo la usa el equipo de Elim.</p>
          </div>

          <div>
            <label class={labelClass} for="nombre_completo">Nombre completo *</label>
            <input class={inputClass} type="text" id="nombre_completo" name="nombre_completo" required />
          </div>

          <div class="grid sm:grid-cols-2 gap-5">
            <div>
              <label class={labelClass} for="cedula">Cédula</label>
              <input class={inputClass} type="text" id="cedula" name="cedula" inputmode="numeric" />
            </div>
            <div>
              <label class={labelClass} for="edad">Edad</label>
              <input class={inputClass} type="number" id="edad" name="edad" min="18" max="100" />
            </div>
          </div>

          <div>
            <label class={labelClass} for="ocupacion">Ocupación</label>
            <input class={inputClass} type="text" id="ocupacion" name="ocupacion" />
          </div>

          <div class="grid sm:grid-cols-2 gap-5">
            <div>
              <label class={labelClass} for="telefono">Teléfono (Colombia, 10 dígitos) *</label>
              <input class={inputClass} type="tel" id="telefono" name="telefono" inputmode="numeric" pattern="[0-9]{10}" placeholder="3103603232" required />
            </div>
            <div>
              <label class={labelClass} for="correo">Correo electrónico *</label>
              <input class={inputClass} type="email" id="correo" name="correo" required />
            </div>
          </div>

          <div>
            <label class={labelClass} for="direccion">Dirección *</label>
            <input class={inputClass} type="text" id="direccion" name="direccion" required />
            <span class={helpClass}>Nos ayuda a ubicar tu hogar para el proceso. Es confidencial.</span>
          </div>

          <div class="grid sm:grid-cols-3 gap-5">
            <div>
              <label class={labelClass} for="ciudad">Ciudad</label>
              <input class={inputClass} type="text" id="ciudad" name="ciudad" />
            </div>
            <div>
              <label class={labelClass} for="barrio">Barrio</label>
              <input class={inputClass} type="text" id="barrio" name="barrio" />
            </div>
            <div>
              <label class={labelClass} for="estrato">Estrato</label>
              <input class={inputClass} type="number" id="estrato" name="estrato" min="1" max="6" />
            </div>
          </div>
        </fieldset>

        <!-- ── STEP 2: Vivienda ───────────────────────── -->
        <fieldset data-step="2" class="space-y-6 hidden">
          <div>
            <p class="text-xs font-bold text-elim-600 uppercase tracking-widest mb-2">Paso 2</p>
            <h2 class={sectionTitleClass}>Tu vivienda</h2>
            <p class={sectionDescClass}>El espacio donde vive el gato importa. Ningún tipo de vivienda es descartable de entrada — solo queremos entender el contexto.</p>
          </div>

          <div>
            <label class={labelClass} for="tipo_vivienda">Tipo de vivienda</label>
            <select class={inputClass} id="tipo_vivienda" name="tipo_vivienda">
              <option value="">Selecciona...</option>
              <option>Casa</option>
              <option>Apartamento</option>
              <option>Finca</option>
              <option>Otro</option>
            </select>
          </div>

          <div>
            <label class={labelClass} for="situacion_habitacional">Situación habitacional</label>
            <select class={inputClass} id="situacion_habitacional" name="situacion_habitacional">
              <option value="">Selecciona...</option>
              <option>Propia</option>
              <option>Arrendada</option>
              <option>Familiar</option>
              <option>Otro</option>
            </select>
          </div>

          <div>
            <span class={labelClass}>¿Tu vivienda tiene mallas de seguridad en ventanas y balcones?</span>
            <div class="flex gap-3 mt-1">
              <label class="flex-1 inline-flex items-center gap-2 px-4 py-3 rounded-xl border border-gray-200 bg-white text-sm cursor-pointer hover:bg-elim-50 hover:border-elim-200 transition">
                <input type="radio" name="mallas_seguridad" value="1" class="accent-elim-600" /> Sí
              </label>
              <label class="flex-1 inline-flex items-center gap-2 px-4 py-3 rounded-xl border border-gray-200 bg-white text-sm cursor-pointer hover:bg-elim-50 hover:border-elim-200 transition">
                <input type="radio" name="mallas_seguridad" value="0" class="accent-elim-600" /> No
              </label>
            </div>
            <span class={helpClass}>Los gatos pueden caer de alturas. Si no tienes mallas, hablemos sobre el plan.</span>
          </div>
        </fieldset>

        <!-- ── STEP 3: Redes y referencias ────────────── -->
        <fieldset data-step="3" class="space-y-6 hidden">
          <div>
            <p class="text-xs font-bold text-elim-600 uppercase tracking-widest mb-2">Paso 3</p>
            <h2 class={sectionTitleClass}>Redes y referencias</h2>
            <p class={sectionDescClass}>Nos ayuda a conocerte mejor y a poder contactar a alguien cercano en caso de necesidad.</p>
          </div>

          <div class="grid sm:grid-cols-2 gap-5">
            <div>
              <label class={labelClass} for="instagram">Instagram</label>
              <input class={inputClass} type="text" id="instagram" name="instagram" placeholder="@usuario" />
            </div>
            <div>
              <label class={labelClass} for="facebook">Facebook</label>
              <input class={inputClass} type="text" id="facebook" name="facebook" />
            </div>
          </div>

          <div>
            <label class={labelClass} for="como_nos_conociste">¿Cómo nos conociste?</label>
            <input class={inputClass} type="text" id="como_nos_conociste" name="como_nos_conociste" placeholder="Instagram, un amigo, búsqueda en Google..." />
          </div>

          <div class="border-t border-gray-100 pt-6">
            <p class="text-sm font-bold text-gray-800 mb-4">Familiar de contacto</p>
            <div class="grid sm:grid-cols-2 gap-5">
              <div>
                <label class={labelClass} for="familiar_nombre">Nombre</label>
                <input class={inputClass} type="text" id="familiar_nombre" name="familiar_nombre" />
              </div>
              <div>
                <label class={labelClass} for="familiar_telefono">Teléfono</label>
                <input class={inputClass} type="tel" id="familiar_telefono" name="familiar_telefono" inputmode="numeric" />
              </div>
            </div>
          </div>

          <div class="border-t border-gray-100 pt-6">
            <p class="text-sm font-bold text-gray-800 mb-4">Referencia personal</p>
            <div class="grid sm:grid-cols-2 gap-5">
              <div>
                <label class={labelClass} for="referencia_nombre">Nombre</label>
                <input class={inputClass} type="text" id="referencia_nombre" name="referencia_nombre" />
              </div>
              <div>
                <label class={labelClass} for="referencia_telefono">Teléfono</label>
                <input class={inputClass} type="tel" id="referencia_telefono" name="referencia_telefono" inputmode="numeric" />
              </div>
            </div>
          </div>
        </fieldset>

        <!-- ── STEP 4: Motivación ─────────────────────── -->
        <fieldset data-step="4" class="space-y-6 hidden">
          <div>
            <p class="text-xs font-bold text-elim-600 uppercase tracking-widest mb-2">Paso 4</p>
            <h2 class={sectionTitleClass}>Tu motivación</h2>
            <p class={sectionDescClass}>Queremos entender por qué quieres adoptar y qué tipo de gato encaja con tu vida.</p>
          </div>

          <div>
            <label class={labelClass} for="por_que_adoptar">¿Por qué quieres adoptar un gato?</label>
            <textarea class={inputClass} id="por_que_adoptar" name="por_que_adoptar" rows="4" placeholder="Cuéntanos en tus propias palabras..."></textarea>
          </div>

          <div class="grid sm:grid-cols-2 gap-5">
            <div>
              <label class={labelClass} for="genero_preferido">Género preferido</label>
              <select class={inputClass} id="genero_preferido" name="genero_preferido">
                <option value="">Selecciona...</option>
                <option>Macho</option>
                <option>Hembra</option>
                <option>Indiferente</option>
              </select>
            </div>
            <div>
              <label class={labelClass} for="edad_estimada_gatito">Edad estimada del gato</label>
              <input class={inputClass} type="text" id="edad_estimada_gatito" name="edad_estimada_gatito" placeholder="Cachorro, joven, adulto, indiferente..." />
            </div>
          </div>

          <div>
            <label class={labelClass} for="responsable_gastos">¿Quién será responsable de los gastos (alimento, veterinaria)?</label>
            <input class={inputClass} type="text" id="responsable_gastos" name="responsable_gastos" />
          </div>

          <div>
            <label class={labelClass} for="cuidador_principal">¿Quién será el cuidador principal en el día a día?</label>
            <input class={inputClass} type="text" id="cuidador_principal" name="cuidador_principal" />
          </div>
        </fieldset>

        <!-- ── STEP 5: Hogar y familia ────────────────── -->
        <fieldset data-step="5" class="space-y-6 hidden">
          <div>
            <p class="text-xs font-bold text-elim-600 uppercase tracking-widest mb-2">Paso 5</p>
            <h2 class={sectionTitleClass}>Tu hogar y familia</h2>
            <p class={sectionDescClass}>El gato va a convivir con todas las personas y mascotas de tu hogar. Cuéntanos del entorno.</p>
          </div>

          <div class="grid sm:grid-cols-2 gap-5">
            <div>
              <label class={labelClass} for="adultos_casa">¿Cuántos adultos viven en casa?</label>
              <input class={inputClass} type="number" id="adultos_casa" name="adultos_casa" min="0" />
            </div>
            <div>
              <label class={labelClass} for="ninos_edades">Edades de los niños (si los hay)</label>
              <input class={inputClass} type="text" id="ninos_edades" name="ninos_edades" placeholder="Ej: 5 y 9 años" />
            </div>
          </div>

          <div>
            <span class={labelClass}>¿Todos en casa están de acuerdo con la adopción?</span>
            <div class="flex gap-3 mt-1">
              <label class="flex-1 inline-flex items-center gap-2 px-4 py-3 rounded-xl border border-gray-200 bg-white text-sm cursor-pointer hover:bg-elim-50 hover:border-elim-200 transition">
                <input type="radio" name="todos_de_acuerdo" value="1" class="accent-elim-600" data-toggles="quien_no_de_acuerdo_wrap" data-toggle-show="0" /> Sí
              </label>
              <label class="flex-1 inline-flex items-center gap-2 px-4 py-3 rounded-xl border border-gray-200 bg-white text-sm cursor-pointer hover:bg-elim-50 hover:border-elim-200 transition">
                <input type="radio" name="todos_de_acuerdo" value="0" class="accent-elim-600" data-toggles="quien_no_de_acuerdo_wrap" data-toggle-show="1" /> No
              </label>
            </div>
            <div id="quien_no_de_acuerdo_wrap" class="hidden mt-3">
              <label class={labelClass} for="quien_no_de_acuerdo">¿Quién no está de acuerdo y por qué?</label>
              <input class={inputClass} type="text" id="quien_no_de_acuerdo" name="quien_no_de_acuerdo" />
            </div>
          </div>

          <div>
            <span class={labelClass}>¿Tienes planes de mudanza en los próximos meses?</span>
            <div class="flex gap-3 mt-1">
              <label class="flex-1 inline-flex items-center gap-2 px-4 py-3 rounded-xl border border-gray-200 bg-white text-sm cursor-pointer hover:bg-elim-50 hover:border-elim-200 transition">
                <input type="radio" name="planes_mudanza" value="1" class="accent-elim-600" data-toggles="cuando_mudanza_wrap" data-toggle-show="1" /> Sí
              </label>
              <label class="flex-1 inline-flex items-center gap-2 px-4 py-3 rounded-xl border border-gray-200 bg-white text-sm cursor-pointer hover:bg-elim-50 hover:border-elim-200 transition">
                <input type="radio" name="planes_mudanza" value="0" class="accent-elim-600" data-toggles="cuando_mudanza_wrap" data-toggle-show="0" /> No
              </label>
            </div>
            <div id="cuando_mudanza_wrap" class="hidden mt-3">
              <label class={labelClass} for="cuando_mudanza">¿Cuándo y a dónde?</label>
              <input class={inputClass} type="text" id="cuando_mudanza" name="cuando_mudanza" />
            </div>
          </div>

          <div>
            <span class={labelClass}>¿Alguien en casa es alérgico a los gatos?</span>
            <div class="flex gap-3 mt-1">
              <label class="flex-1 inline-flex items-center gap-2 px-4 py-3 rounded-xl border border-gray-200 bg-white text-sm cursor-pointer hover:bg-elim-50 hover:border-elim-200 transition">
                <input type="radio" name="alguien_alergico" value="1" class="accent-elim-600" data-toggles="quien_alergico_wrap" data-toggle-show="1" /> Sí
              </label>
              <label class="flex-1 inline-flex items-center gap-2 px-4 py-3 rounded-xl border border-gray-200 bg-white text-sm cursor-pointer hover:bg-elim-50 hover:border-elim-200 transition">
                <input type="radio" name="alguien_alergico" value="0" class="accent-elim-600" data-toggles="quien_alergico_wrap" data-toggle-show="0" /> No
              </label>
            </div>
            <div id="quien_alergico_wrap" class="hidden mt-3">
              <label class={labelClass} for="quien_alergico">¿Quién y qué tan severa?</label>
              <input class={inputClass} type="text" id="quien_alergico" name="quien_alergico" />
            </div>
          </div>

          <div class="border-t border-gray-100 pt-6">
            <span class={labelClass}>¿Tienes otras mascotas actualmente?</span>
            <div class="flex gap-3 mt-1">
              <label class="flex-1 inline-flex items-center gap-2 px-4 py-3 rounded-xl border border-gray-200 bg-white text-sm cursor-pointer hover:bg-elim-50 hover:border-elim-200 transition">
                <input type="radio" name="tiene_otras_mascotas" value="1" class="accent-elim-600" data-toggles="otras_mascotas_wrap" data-toggle-show="1" /> Sí
              </label>
              <label class="flex-1 inline-flex items-center gap-2 px-4 py-3 rounded-xl border border-gray-200 bg-white text-sm cursor-pointer hover:bg-elim-50 hover:border-elim-200 transition">
                <input type="radio" name="tiene_otras_mascotas" value="0" class="accent-elim-600" data-toggles="otras_mascotas_wrap" data-toggle-show="0" /> No
              </label>
            </div>
            <div id="otras_mascotas_wrap" class="hidden mt-4 space-y-5">
              <div>
                <label class={labelClass} for="otras_mascotas_tipo">¿Qué tipo de mascotas y cuántas?</label>
                <input class={inputClass} type="text" id="otras_mascotas_tipo" name="otras_mascotas_tipo" placeholder="Ej: 1 perro adulto, 2 gatos" />
              </div>
              <div>
                <span class={labelClass}>¿Están esterilizadas?</span>
                <div class="flex gap-3 mt-1">
                  <label class="flex-1 inline-flex items-center gap-2 px-4 py-3 rounded-xl border border-gray-200 bg-white text-sm cursor-pointer hover:bg-elim-50 hover:border-elim-200 transition">
                    <input type="radio" name="otras_esterilizadas" value="1" class="accent-elim-600" /> Sí
                  </label>
                  <label class="flex-1 inline-flex items-center gap-2 px-4 py-3 rounded-xl border border-gray-200 bg-white text-sm cursor-pointer hover:bg-elim-50 hover:border-elim-200 transition">
                    <input type="radio" name="otras_esterilizadas" value="0" class="accent-elim-600" /> No
                  </label>
                </div>
              </div>
              <div>
                <label class={labelClass} for="otras_alimento">¿Qué alimento les das?</label>
                <input class={inputClass} type="text" id="otras_alimento" name="otras_alimento" />
              </div>
              <div>
                <label class={labelClass} for="otras_anteriores">¿Has tenido otras mascotas antes? ¿Qué pasó con ellas?</label>
                <textarea class={inputClass} id="otras_anteriores" name="otras_anteriores" rows="3"></textarea>
              </div>
            </div>
          </div>
        </fieldset>

        <!-- ── STEP 6: Compromiso ─────────────────────── -->
        <fieldset data-step="6" class="space-y-6 hidden">
          <div>
            <p class="text-xs font-bold text-elim-600 uppercase tracking-widest mb-2">Paso 6</p>
            <h2 class={sectionTitleClass}>Tu compromiso</h2>
            <p class={sectionDescClass}>La última parte. Aquí pensamos juntos los escenarios reales que pueden venir con la adopción.</p>
          </div>

          <div>
            <label class={labelClass} for="plan_dificultad_economica">¿Qué harías si pasas por una dificultad económica?</label>
            <textarea class={inputClass} id="plan_dificultad_economica" name="plan_dificultad_economica" rows="3"></textarea>
          </div>

          <div>
            <label class={labelClass} for="plan_comportamiento">¿Qué harías si el gato presenta problemas de comportamiento (arañazos, orines fuera del arenero, etc.)?</label>
            <textarea class={inputClass} id="plan_comportamiento" name="plan_comportamiento" rows="3"></textarea>
          </div>

          <div>
            <label class={labelClass} for="plan_enfermedad">¿Qué harías si el gato se enferma y requiere tratamiento prolongado o costoso?</label>
            <textarea class={inputClass} id="plan_enfermedad" name="plan_enfermedad" rows="3"></textarea>
          </div>

          <div>
            <label class={labelClass} for="plan_vacaciones">¿Qué haces con el gato cuando sales de viaje o vacaciones?</label>
            <textarea class={inputClass} id="plan_vacaciones" name="plan_vacaciones" rows="3"></textarea>
          </div>

          <div class="border-t border-gray-100 pt-6">
            <span class={labelClass}>Apoya a los gatos de Elim 💛</span>
            <p class="text-xs text-gray-500 mb-4">Adoptar no exige donar, pero cada aporte sostiene el refugio —alimento, arena y esterilizaciones para los gatos que aún esperan hogar. Elige cómo quieres ayudar.</p>
            <div class="space-y-3">
              <label class="flex items-center gap-3 px-4 py-3 rounded-xl border border-gray-200 bg-white cursor-pointer hover:bg-elim-50 hover:border-elim-200 transition">
                <input type="radio" name="donacion_tipo" value="Arenero al día" data-monto="20000" class="accent-elim-600" />
                <span class="text-2xl">🪣</span>
                <span class="flex-1 text-sm"><span class="font-semibold text-gray-900">Arenero al día</span><br/><span class="text-gray-500 text-xs">Arena para los gatos del refugio</span></span>
                <span class="font-bold text-elim-700 text-sm whitespace-nowrap">$20.000</span>
              </label>
              <label class="flex items-center gap-3 px-4 py-3 rounded-xl border border-gray-200 bg-white cursor-pointer hover:bg-elim-50 hover:border-elim-200 transition">
                <input type="radio" name="donacion_tipo" value="Barriga llena" data-monto="50000" class="accent-elim-600" />
                <span class="text-2xl">🍽️</span>
                <span class="flex-1 text-sm"><span class="font-semibold text-gray-900">Barriga llena</span><br/><span class="text-gray-500 text-xs">Alimento para un gato</span></span>
                <span class="font-bold text-elim-700 text-sm whitespace-nowrap">$50.000</span>
              </label>
              <label class="flex items-center gap-3 px-4 py-3 rounded-xl border border-gray-200 bg-white cursor-pointer hover:bg-elim-50 hover:border-elim-200 transition">
                <input type="radio" name="donacion_tipo" value="Una vida protegida" data-monto="100000" class="accent-elim-600" />
                <span class="text-2xl">✂️</span>
                <span class="flex-1 text-sm"><span class="font-semibold text-gray-900">Una vida protegida</span><br/><span class="text-gray-500 text-xs">Aporta a una esterilización</span></span>
                <span class="font-bold text-elim-700 text-sm whitespace-nowrap">$100.000</span>
              </label>
              <label class="flex items-center gap-3 px-4 py-3 rounded-xl border border-gray-200 bg-white cursor-pointer hover:bg-elim-50 hover:border-elim-200 transition">
                <input type="radio" name="donacion_tipo" value="Otro monto" data-otro="1" class="accent-elim-600" />
                <span class="text-2xl">✍️</span>
                <span class="flex-1 text-sm"><span class="font-semibold text-gray-900">Otro monto</span><br/><span class="text-gray-500 text-xs">Aporta lo que quieras</span></span>
              </label>
              <div id="donacion_otro_wrap" class="hidden pl-4">
                <input class={inputClass} type="number" id="donacion_monto" name="donacion_monto" min="0" placeholder="¿Cuánto quieres aportar? (COP)" />
              </div>
              <label class="flex items-center gap-3 px-4 py-3 rounded-xl border border-gray-200 bg-white cursor-pointer hover:bg-elim-50 hover:border-elim-200 transition">
                <input type="radio" name="donacion_tipo" value="Aporte en especie" class="accent-elim-600" />
                <span class="text-2xl">🎁</span>
                <span class="flex-1 text-sm"><span class="font-semibold text-gray-900">Aporte en especie</span><br/><span class="text-gray-500 text-xs">Alimento, arena, insumos…</span></span>
              </label>
              <label class="flex items-center gap-3 px-4 py-3 rounded-xl border border-gray-200 bg-white cursor-pointer hover:bg-elim-50 hover:border-elim-200 transition">
                <input type="radio" name="donacion_tipo" value="Por ahora no puedo aportar" class="accent-elim-600" />
                <span class="text-2xl">🙏</span>
                <span class="flex-1 text-sm"><span class="font-semibold text-gray-900">Por ahora no puedo aportar</span></span>
              </label>
            </div>
          </div>

          <div class="border-t border-gray-100 pt-6">
            <span class={labelClass}>Compromisos de adopción responsable</span>
            <p class="text-xs text-gray-500 mb-4">Marca los compromisos que estás dispuesto a asumir. Todos son parte del proceso.</p>
            <div class="space-y-3">
              {compromisos.map((c) => (
                <label class="flex items-start gap-3 px-4 py-3 rounded-xl border border-gray-200 bg-white cursor-pointer hover:bg-elim-50 hover:border-elim-200 transition">
                  <input type="checkbox" name="compromisos_aceptados" value={c} class="mt-0.5 accent-elim-600" />
                  <span class="text-sm text-gray-700">{c}</span>
                </label>
              ))}
            </div>
          </div>

          <div class="border-t border-gray-100 pt-6">
            <label class="flex items-start gap-3 px-4 py-4 rounded-xl border border-elim-200 bg-elim-50 cursor-pointer">
              <input type="checkbox" name="declaracion_final" value="1" class="mt-0.5 accent-elim-600" required />
              <span class="text-sm text-gray-800 font-medium">
                Declaro que la información proporcionada es verdadera y entiendo que la adopción es un compromiso de por vida. *
              </span>
            </label>
          </div>
        </fieldset>

        <!-- NAV BUTTONS -->
        <div class="flex items-center justify-between pt-6 border-t border-gray-100">
          <button type="button" id="btnPrev" class="inline-flex items-center gap-2 bg-white border border-gray-200 hover:bg-gray-50 text-gray-700 font-semibold px-6 py-3 rounded-xl transition-colors text-sm disabled:opacity-40 disabled:cursor-not-allowed" disabled>
            ← Anterior
          </button>
          <button type="button" id="btnNext" class="inline-flex items-center gap-2 bg-elim-600 hover:bg-elim-500 text-white font-bold px-7 py-3 rounded-xl transition-colors shadow-lg shadow-elim-900/20 text-sm">
            Siguiente →
          </button>
          <button type="submit" id="btnSubmit" class="hidden items-center gap-2 bg-elim-700 hover:bg-elim-800 text-white font-bold px-7 py-3 rounded-xl transition-colors shadow-lg shadow-elim-900/20 text-sm">
            Enviar postulación
          </button>
        </div>

        <p class="text-xs text-gray-400 text-center pt-2">
          * Campos obligatorios. Tu información se guarda de forma segura y solo es vista por el equipo de Elim.
        </p>

      </form>
    </div>
  </section>

</Layout>

<script is:inline>
  (function () {
    const STORAGE_KEY = 'elim-adopcion-draft';
    const TOTAL_STEPS = 6;
    const STEP_LABELS = {
      1: 'Datos personales',
      2: 'Tu vivienda',
      3: 'Redes y referencias',
      4: 'Tu motivación',
      5: 'Tu hogar y familia',
      6: 'Compromiso',
    };
    const REQUIRED_BY_STEP = {
      1: ['nombre_completo', 'telefono', 'correo', 'direccion'],
      2: [],
      3: [],
      4: [],
      5: [],
      6: ['declaracion_final'],
    };

    const form = document.getElementById('adoptForm');
    if (!form) return;

    const btnPrev = document.getElementById('btnPrev');
    const btnNext = document.getElementById('btnNext');
    const btnSubmit = document.getElementById('btnSubmit');
    const stepLabel = document.getElementById('stepLabel');
    const stepCount = document.getElementById('stepCount');
    const progressBar = document.getElementById('progressBar');
    const errorBanner = document.getElementById('errorBanner');
    const errorMsg = document.getElementById('errorMsg');
    const thankYou = document.getElementById('thankYou');

    let currentStep = 1;

    function setStep(n) {
      currentStep = Math.max(1, Math.min(TOTAL_STEPS, n));
      form.querySelectorAll('fieldset[data-step]').forEach(fs => {
        fs.classList.toggle('hidden', Number(fs.dataset.step) !== currentStep);
      });
      stepLabel.textContent = `Paso ${currentStep} de ${TOTAL_STEPS} · ${STEP_LABELS[currentStep]}`;
      stepCount.textContent = `${currentStep} / ${TOTAL_STEPS}`;
      progressBar.style.width = `${(currentStep / TOTAL_STEPS) * 100}%`;
      btnPrev.disabled = currentStep === 1;
      if (currentStep === TOTAL_STEPS) {
        btnNext.classList.add('hidden');
        btnSubmit.classList.remove('hidden');
        btnSubmit.classList.add('inline-flex');
      } else {
        btnNext.classList.remove('hidden');
        btnSubmit.classList.add('hidden');
        btnSubmit.classList.remove('inline-flex');
      }
      window.scrollTo({ top: form.offsetTop - 80, behavior: 'smooth' });
    }

    function showError(msg) {
      errorMsg.textContent = msg || 'Por favor intenta de nuevo en unos minutos.';
      errorBanner.classList.remove('hidden');
      window.scrollTo({ top: errorBanner.offsetTop - 80, behavior: 'smooth' });
    }
    function clearError() { errorBanner.classList.add('hidden'); }

    function validateEmail(v) { return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(String(v || '').trim()); }
    function validatePhoneCO(v) {
      const digits = String(v || '').replace(/\D/g, '');
      return digits.length === 10;
    }

    function validateStep(step) {
      const required = REQUIRED_BY_STEP[step] || [];
      for (const name of required) {
        if (name === 'declaracion_final') {
          const cb = form.querySelector('input[name="declaracion_final"]');
          if (!cb || !cb.checked) {
            showError('Debes aceptar la declaración final para continuar.');
            return false;
          }
          continue;
        }
        const el = form.querySelector(`[name="${name}"]`);
        if (!el || !String(el.value || '').trim()) {
          showError('Por favor completa los campos obligatorios marcados con *.');
          if (el) el.focus();
          return false;
        }
      }
      if (step === 1) {
        const correo = form.querySelector('[name="correo"]').value;
        if (!validateEmail(correo)) {
          showError('Por favor ingresa un correo electrónico válido.');
          return false;
        }
        const tel = form.querySelector('[name="telefono"]').value;
        if (!validatePhoneCO(tel)) {
          showError('El teléfono debe tener 10 dígitos (formato Colombia).');
          return false;
        }
      }
      clearError();
      return true;
    }

    btnNext.addEventListener('click', () => {
      if (!validateStep(currentStep)) return;
      saveDraft();
      setStep(currentStep + 1);
    });
    btnPrev.addEventListener('click', () => {
      saveDraft();
      setStep(currentStep - 1);
    });

    form.querySelectorAll('input[data-toggles]').forEach(input => {
      input.addEventListener('change', () => {
        const targetId = input.dataset.toggles;
        const show = input.dataset.toggleShow === '1';
        const wrap = document.getElementById(targetId);
        if (!wrap) return;
        if (input.checked) wrap.classList.toggle('hidden', !show);
      });
    });

    const donacionRadios = form.querySelectorAll('input[name="donacion_tipo"]');
    const donacionOtroWrap = document.getElementById('donacion_otro_wrap');
    const donacionMonto = document.getElementById('donacion_monto');
    donacionRadios.forEach(r => {
      r.addEventListener('change', () => {
        if (!r.checked) return;
        const isOtro = r.dataset.otro === '1';
        donacionOtroWrap.classList.toggle('hidden', !isOtro);
        if (isOtro) { donacionMonto.value = ''; donacionMonto.focus(); }
        else if (r.dataset.monto) { donacionMonto.value = r.dataset.monto; }
        else { donacionMonto.value = ''; }
      });
    });

    function collectFormData() {
      const data = {};
      const fd = new FormData(form);
      for (const [key, value] of fd.entries()) {
        if (key === 'compromisos_aceptados') {
          if (!data[key]) data[key] = [];
          data[key].push(value);
        } else if (data[key] !== undefined) {
          if (!Array.isArray(data[key])) data[key] = [data[key]];
          data[key].push(value);
        } else {
          data[key] = value;
        }
      }
      if (!data.compromisos_aceptados) data.compromisos_aceptados = [];
      data.declaracion_final = form.querySelector('input[name="declaracion_final"]').checked ? 1 : 0;
      ['mallas_seguridad', 'todos_de_acuerdo', 'planes_mudanza', 'alguien_alergico', 'tiene_otras_mascotas', 'otras_esterilizadas'].forEach(k => {
        if (data[k] !== undefined && data[k] !== '') data[k] = Number(data[k]);
      });
      return data;
    }

    function saveDraft() {
      try {
        const data = collectFormData();
        delete data._website;
        localStorage.setItem(STORAGE_KEY, JSON.stringify({ step: currentStep, data }));
      } catch (e) {}
    }

    function restoreDraft() {
      try {
        const raw = localStorage.getItem(STORAGE_KEY);
        if (!raw) return;
        const parsed = JSON.parse(raw);
        if (!parsed || !parsed.data) return;
        const data = parsed.data;
        Object.keys(data).forEach(key => {
          const val = data[key];
          const inputs = form.querySelectorAll(`[name="${key}"]`);
          if (!inputs.length) return;
          if (inputs[0].type === 'radio') {
            inputs.forEach(i => { i.checked = String(i.value) === String(val); i.dispatchEvent(new Event('change')); });
          } else if (inputs[0].type === 'checkbox') {
            const arr = Array.isArray(val) ? val.map(String) : [String(val)];
            inputs.forEach(i => { i.checked = arr.includes(i.value) || (i.value === '1' && (val === 1 || val === '1' || val === true)); });
          } else if (inputs[0].tagName === 'SELECT') {
            inputs[0].value = val;
            inputs[0].dispatchEvent(new Event('change'));
          } else {
            inputs[0].value = val;
          }
        });
        if (parsed.step) setStep(parsed.step);
      } catch (e) {}
    }

    form.addEventListener('input', () => { saveDraft(); });
    form.addEventListener('change', () => { saveDraft(); });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!validateStep(TOTAL_STEPS)) return;
      const compromisos = Array.from(form.querySelectorAll('input[name="compromisos_aceptados"]:checked')).map(i => i.value);
      if (compromisos.length === 0) {
        showError('Por favor marca al menos un compromiso de adopción responsable.');
        return;
      }
      clearError();
      btnSubmit.disabled = true;
      btnSubmit.textContent = 'Enviando...';

      const payload = collectFormData();
      payload._website = document.getElementById('_website').value;

      try {
        const res = await fetch('/api/solicitud', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        const json = await res.json().catch(() => ({}));
        if (!res.ok || !json.ok) {
          throw new Error(json.error || 'submit_failed');
        }
        localStorage.removeItem(STORAGE_KEY);
        try { sessionStorage.setItem('adopcion_enviada', '1'); } catch (e) {}
        window.location.href = '/refugio/solicitud-enviada';
      } catch (err) {
        showError('No pudimos enviar tu postulación en este momento. Por favor intenta de nuevo o escríbenos por WhatsApp.');
        btnSubmit.disabled = false;
        btnSubmit.textContent = 'Enviar postulación';
      }
    });

    restoreDraft();
    if (currentStep < 1 || currentStep > TOTAL_STEPS) setStep(1);
    else setStep(currentStep);
  })();
</script>
