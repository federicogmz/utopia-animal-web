---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Jornada de Esterilización Bajo Costo – Junio 2026 | Utopía Animal Vet, Medellín"
  description="Esteriliza a tu perro o gato en Medellín desde $80.000 con cirugía, anestesia y medicamentos incluidos. Cupos limitados el 27 y 28 de junio en Guayabal."
  seoType="veterinary"
  brand="utopia"
>

  <!-- HERO -->
  <section class="bg-gradient-to-br from-utopia-950 via-utopia-900 to-gray-950 pt-24 pb-16 relative overflow-hidden">
    <div class="absolute top-0 right-0 w-96 h-96 bg-utopia-orange opacity-5 rounded-full blur-3xl -translate-y-1/2 translate-x-1/3"></div>
    <div class="max-w-4xl mx-auto px-4 sm:px-6 relative text-center">
      <div class="inline-flex items-center gap-2 bg-orange-500/20 border border-orange-400/30 text-orange-300 text-xs font-bold px-4 py-2 rounded-full mb-6 uppercase tracking-wider">
        <span class="w-2 h-2 bg-orange-400 rounded-full animate-pulse"></span>
        Cupos limitados · Junio 2026
      </div>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white leading-tight mb-4">
        Jornada de<br/>
        <span class="text-utopia-400">Esterilización</span><br/>
        Bajo Costo
      </h1>
      <p class="text-utopia-200 text-xl leading-relaxed mb-8 max-w-2xl mx-auto">
        Cirugía, anestesia y medicamentos incluidos. Para perros y gatos en Medellín, Guayabal.
      </p>
      <a
        href="https://api.whatsapp.com/send?phone=573215308188&text=Hola,%20quiero%20agendar%20en%20la%20jornada%20de%20esterilizaci%C3%B3n%20de%20junio"
        target="_blank" rel="noopener"
        class="inline-flex items-center gap-3 bg-green-500 hover:bg-green-400 text-white font-bold px-8 py-4 rounded-xl text-lg transition-colors shadow-lg shadow-green-900/40"
      >
        💬 Agendar por WhatsApp · 321 530 8188
      </a>
    </div>
    <div class="relative -mb-px mt-10">
      <svg viewBox="0 0 1440 50" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full">
        <path d="M0 50L1440 50L1440 0Q720 50 0 0Z" fill="white"/>
      </svg>
    </div>
  </section>

  <!-- FECHAS Y PRECIOS -->
  <section class="bg-white py-20">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-14">
        <p class="text-xs font-bold text-utopia-500 uppercase tracking-widest mb-3">Cuándo y cuánto</p>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-gray-900">Fechas y precios</h2>
      </div>

      <div class="grid md:grid-cols-2 gap-8">

        <!-- GATOS -->
        <div class="rounded-2xl border-2 border-utopia-200 overflow-hidden shadow-sm">
          <div class="bg-utopia-50 px-6 py-4 flex items-center gap-3">
            <span class="text-3xl">🐱</span>
            <div>
              <h3 class="text-xl font-extrabold text-utopia-900">Gatos</h3>
              <p class="text-sm font-semibold text-utopia-600">Sábado 27 de junio</p>
            </div>
          </div>
          <div class="px-6 py-6">
            <div class="grid grid-cols-2 gap-4">
              <div class="bg-pink-50 rounded-xl p-4 text-center">
                <p class="text-xs font-bold text-pink-500 uppercase tracking-wide mb-1">Hembra</p>
                <p class="text-3xl font-extrabold text-gray-900">$100k</p>
              </div>
              <div class="bg-blue-50 rounded-xl p-4 text-center">
                <p class="text-xs font-bold text-blue-500 uppercase tracking-wide mb-1">Macho</p>
                <p class="text-3xl font-extrabold text-gray-900">$80k</p>
              </div>
            </div>
          </div>
        </div>

        <!-- PERROS -->
        <div class="rounded-2xl border-2 border-utopia-200 overflow-hidden shadow-sm">
          <div class="bg-utopia-50 px-6 py-4 flex items-center gap-3">
            <span class="text-3xl">🐶</span>
            <div>
              <h3 class="text-xl font-extrabold text-utopia-900">Perros</h3>
              <p class="text-sm font-semibold text-utopia-600">Domingo 28 de junio</p>
            </div>
          </div>
          <div class="px-6 py-6">
            <table class="w-full text-sm">
              <thead>
                <tr class="text-xs font-bold text-gray-500 uppercase border-b border-gray-100">
                  <th class="text-left pb-2">Peso</th>
                  <th class="text-center pb-2 text-pink-500">Hembra</th>
                  <th class="text-center pb-2 text-blue-500">Macho</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-50">
                <tr class="py-2">
                  <td class="py-2 font-medium text-gray-700">0–10 kg</td>
                  <td class="py-2 text-center font-bold text-gray-900">$150k</td>
                  <td class="py-2 text-center font-bold text-gray-900">$120k</td>
                </tr>
                <tr>
                  <td class="py-2 font-medium text-gray-700">11–20 kg</td>
                  <td class="py-2 text-center font-bold text-gray-900">$180k</td>
                  <td class="py-2 text-center font-bold text-gray-900">$140k</td>
                </tr>
                <tr>
                  <td class="py-2 font-medium text-gray-700">21–30 kg</td>
                  <td class="py-2 text-center font-bold text-gray-900">$220k</td>
                  <td class="py-2 text-center font-bold text-gray-900">$170k</td>
                </tr>
                <tr>
                  <td class="py-2 font-medium text-gray-700">31–50 kg</td>
                  <td class="py-2 text-center font-bold text-gray-900">$260k</td>
                  <td class="py-2 text-center font-bold text-gray-900">$200k</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- INCLUYE / NO INCLUYE -->
      <div class="mt-8 grid sm:grid-cols-2 gap-4">
        <div class="bg-green-50 border border-green-200 rounded-xl p-5">
          <p class="font-bold text-green-800 mb-2">✅ Incluye</p>
          <ul class="space-y-1 text-sm text-green-700">
            <li>Cirugía de esterilización</li>
            <li>Anestesia general</li>
            <li>Medicamentos del protocolo</li>
          </ul>
        </div>
        <div class="bg-amber-50 border border-amber-200 rounded-xl p-5">
          <p class="font-bold text-amber-800 mb-2">⚠️ Condiciones</p>
          <ul class="space-y-1 text-sm text-amber-700">
            <li>No incluye exámenes prequirúrgicos</li>
            <li>No incluye medicamentos postoperatorios adicionales</li>
            <li>No aplica para gestantes ni patologías previas</li>
          </ul>
        </div>
      </div>

    </div>
  </section>

  <!-- UBICACION + CTA -->
  <section class="bg-gray-50 py-20">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 text-center">
      <div class="text-4xl mb-4">📍</div>
      <h2 class="text-2xl font-extrabold text-gray-900 mb-2">¿Dónde?</h2>
      <p class="text-gray-600 text-lg mb-1"><strong>Utopía Animal Veterinaria</strong></p>
      <p class="text-gray-500 mb-8">Cra 52 #2 sur-60, Guayabal – Cristo Rey, Medellín</p>
      <a
        href="https://api.whatsapp.com/send?phone=573215308188&text=Hola,%20quiero%20agendar%20en%20la%20jornada%20de%20esterilizaci%C3%B3n%20de%20junio"
        target="_blank" rel="noopener"
        class="inline-flex items-center gap-3 bg-green-500 hover:bg-green-400 text-white font-bold px-8 py-4 rounded-xl text-xl transition-colors shadow-lg"
      >
        💬 Quiero mi cupo – WhatsApp
      </a>
      <p class="text-gray-400 text-sm mt-4">Cupos limitados, se asignan por orden de agendamiento</p>
    </div>
  </section>

  <!-- FAQ RÁPIDO -->
  <section class="bg-white py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <h2 class="text-2xl font-extrabold text-gray-900 mb-8 text-center">Preguntas frecuentes</h2>
      <div class="space-y-4">
        {[
          { q: "¿Mi animal necesita ayuno previo?", a: "Sí. Debe llegar sin haber comido 8 a 12 horas antes del procedimiento. Solo agua está permitida." },
          { q: "¿Cuándo se va a casa?", a: "El mismo día, horas después de recuperarse de la anestesia. Te avisamos cuando pueda irse." },
          { q: "¿Necesito exámenes prequirúrgicos?", a: "No son obligatorios, pero si tu animal tiene más de 7 años o tiene alguna condición, lo recomendamos. Escríbenos y te orientamos." },
          { q: "¿Aplica para perras o gatas preñadas?", a: "No. La jornada no aplica para hembras en gestación ni para animales con patologías previas diagnosticadas." },
        ].map(({ q, a }) => (
          <div class="border border-gray-200 rounded-xl p-5">
            <p class="font-bold text-gray-900 mb-1">{q}</p>
            <p class="text-gray-600 text-sm">{a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

</Layout>
