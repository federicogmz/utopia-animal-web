---
import Layout from '../layouts/Layout.astro';
import BlogCard from '../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<Layout
  title="Utopía Animal - Bienestar Animal en Medellín"
  description="Utopía Animal: veterinaria humanizada (Vet), rescate y adopción (Elim) y educación en bienestar animal. Construimos una Medellín más consciente con los animales que la habitan."
  seoType="organization"
>

  <!-- HERO -->
  <section class="relative bg-gradient-to-br from-utopia-950 via-utopia-900 to-gray-950 overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <pattern id="dots" x="0" y="0" width="40" height="40" patternUnits="userSpaceOnUse">
            <circle cx="2" cy="2" r="1.5" fill="white"/>
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#dots)"/>
      </svg>
    </div>
    <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-utopia-500 opacity-5 rounded-full blur-3xl -translate-y-1/2 translate-x-1/3"></div>
    <div class="absolute bottom-0 left-0 w-96 h-96 bg-elim-500 opacity-5 rounded-full blur-3xl translate-y-1/2 -translate-x-1/4"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 pt-20 pb-10 sm:pt-28 sm:pb-12">
      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 bg-white/10 border border-white/20 text-white/80 text-xs font-semibold px-4 py-2 rounded-full mb-8 backdrop-blur-sm">
          <span class="w-1.5 h-1.5 bg-utopia-orange rounded-full animate-pulse"></span>
          Utopía Animal · Medellín, Colombia · Bienestar Animal
        </div>
        <h1 class="text-5xl sm:text-6xl lg:text-7xl font-extrabold text-white leading-[1.05] mb-6">
          El bienestar animal<br/>
          como<br/>
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-utopia-orange to-utopia-400">arquitectura social.</span>
        </h1>
        <p class="text-lg sm:text-xl text-white/70 leading-relaxed mb-10 max-w-2xl">
          Utopía Animal cree que la forma en que tratamos a los animales que nos acompañan dice todo sobre quiénes somos. Actuamos en veterinaria, rescate y educación.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="/veterinaria"
            class="inline-flex items-center gap-2 bg-utopia-500 hover:bg-utopia-400 text-white font-bold px-7 py-3.5 rounded-xl transition-colors shadow-lg shadow-utopia-900/50 text-sm">
            🐾 Ir a la veterinaria
          </a>
          <a href="/refugio"
            class="inline-flex items-center gap-2 bg-white/10 hover:bg-white/20 text-white font-semibold px-7 py-3.5 rounded-xl transition-colors border border-white/20 text-sm">
            🐱 Refugio Elim
          </a>
          <a href="/apoya"
            class="inline-flex items-center gap-2 bg-white/10 hover:bg-white/20 text-white font-semibold px-7 py-3.5 rounded-xl transition-colors border border-white/20 text-sm">
            💚 Apoyar
          </a>
        </div>

        <!-- Prueba social -->
        <div class="flex flex-wrap items-center gap-x-6 gap-y-2 mt-9 text-sm text-white/60">
          <span>Seguimiento de por vida a cada adopción</span>
          <span class="text-white/30">·</span>
          <span>Veterinaria en <strong class="text-white">Av Guayabal</strong></span>
        </div>
      </div>
    </div>

    <div class="relative -mb-px">
      <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full">
        <path d="M0 60L48 50C96 40 192 20 288 15C384 10 480 20 576 28C672 36 768 40 864 36C960 32 1056 20 1152 15C1248 10 1344 12 1392 13L1440 14V60H0Z" fill="white"/>
      </svg>
    </div>
  </section>

  <!-- PILARES -->
  <section class="bg-white py-10 border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {[
          { icon: '🩺', label: 'Veterinaria humanizada', sub: 'Perros, gatos y más', color: 'text-utopia-600', href: '/veterinaria' },
          { icon: '🐱', label: 'Adopta un gato', sub: 'Gatos en adopción en Medellín', color: 'text-elim-600', href: '/refugio/adoptar/' },
          { icon: '💉', label: 'Esterilización', sub: 'Jornadas subsidiadas', color: 'text-utopia-500', href: '/veterinaria/jornada-esterilizacion/' },
          { icon: '📚', label: 'Educación', sub: 'Blog de bienestar animal', color: 'text-elim-500', href: '/blog' },
        ].map(({ icon, label, sub, color, href }) => (
          <a href={href}
            class="block text-center py-5 px-4 rounded-2xl bg-gray-50 border border-gray-100 hover:bg-gray-100 hover:border-gray-200 hover:shadow-sm transition-all">
            <div class={`text-3xl mb-2`}>{icon}</div>
            <div class={`text-sm font-bold ${color} mb-0.5`}>{label}</div>
            <div class="text-xs text-gray-400">{sub}</div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- VETERINARIA - ÉNFASIS PRINCIPAL -->
  <section class="bg-white py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div>
          <div class="flex items-center gap-2 mb-4">
            <img src="/logo-utopia.png" alt="Utopía Animal Vet" class="w-10 h-10 object-contain" loading="lazy"/>
            <span class="text-xs font-bold text-utopia-500 uppercase tracking-widest">Veterinaria</span>
          </div>
          <h2 class="text-4xl sm:text-5xl font-extrabold text-gray-900 leading-tight mb-6">
            La veterinaria que<br/>te acompaña de verdad.
          </h2>
          <p class="text-gray-600 text-lg leading-relaxed mb-6">
            Atención de calidad a un costo justo, con profesionales que se toman el tiempo de explicarte todo. Porque cuidar bien a tu compañero de vida no debería ser un privilegio.
          </p>
          <p class="text-gray-500 leading-relaxed mb-8">
            Consulta general, medicina preventiva, cirugías, urgencias, vacunas, grooming y petshop, todo en un solo lugar, como parte de Utopía Animal.
          </p>
          <div class="grid grid-cols-2 gap-3 mb-8">
            {[
              'Consulta y medicina preventiva',
              'Urgencias en horario',
              'Esterilización y cirugías',
              'Vacunas y desparasitación',
              'Grooming',
              'Pet Shop',
            ].map(s => (
              <div class="flex items-center gap-2 text-sm text-gray-600">
                <span class="w-1.5 h-1.5 rounded-full bg-utopia-400 shrink-0"></span>
                {s}
              </div>
            ))}
          </div>
          <div class="flex flex-wrap gap-3">
            <a href="/veterinaria"
              class="inline-flex items-center gap-2 bg-utopia-500 hover:bg-utopia-600 text-white font-bold px-6 py-3 rounded-xl transition-colors text-sm">
              Ver todos los servicios →
            </a>
            <a href="https://api.whatsapp.com/send?phone=573215308188&text=Hola,%20quiero%20agendar%20una%20cita%20en%20Utop%C3%ADa%20Animal%20Vet"
              target="_blank" rel="noopener"
              class="inline-flex items-center gap-2 bg-green-50 hover:bg-green-100 text-green-700 font-semibold px-6 py-3 rounded-xl transition-colors text-sm border border-green-200">
              💬 Agendar por WhatsApp
            </a>
          </div>
        </div>
        <div class="bg-utopia-50 rounded-3xl p-8 border border-utopia-100">
          <p class="text-xs font-bold text-utopia-500 uppercase tracking-widest mb-5">Horarios y ubicación</p>
          <div class="space-y-5">
            <div class="flex items-start gap-4">
              <div class="w-9 h-9 bg-utopia-100 rounded-xl flex items-center justify-center shrink-0">
                <svg class="w-4 h-4 text-utopia-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              </div>
              <div>
                <p class="font-semibold text-gray-900 text-sm">Horario de atención</p>
                <p class="text-gray-600 text-sm">Lunes a Sábado · 9:30 am – 6:00 pm</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-9 h-9 bg-utopia-100 rounded-xl flex items-center justify-center shrink-0">
                <svg class="w-4 h-4 text-utopia-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
              </div>
              <div>
                <p class="font-semibold text-gray-900 text-sm">Dirección</p>
                <p class="text-gray-600 text-sm">Cra. 52 # 2 Sur 60, Av Guayabal<br/>Medellín, Antioquia</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-9 h-9 bg-utopia-100 rounded-xl flex items-center justify-center shrink-0">
                <svg class="w-4 h-4 text-utopia-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.948V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                </svg>
              </div>
              <div>
                <p class="font-semibold text-gray-900 text-sm">WhatsApp</p>
                <a href="https://api.whatsapp.com/send?phone=573215308188" class="text-utopia-600 text-sm hover:underline">+57 321 530 8188</a>
              </div>
            </div>
          </div>
          <div class="mt-6 pt-6 border-t border-utopia-100">
            <p class="text-xs text-gray-500 italic">Urgencias atendidas en horario de atención. Si es urgente, escríbenos indicando "URGENCIA" en el mensaje.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- UTOPÍA ANIMAL - FILOSOFÍA -->
  <section class="bg-utopia-950 py-24 relative overflow-hidden">
    <div class="absolute inset-0 opacity-5">
      <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
        <defs><pattern id="dots2" x="0" y="0" width="40" height="40" patternUnits="userSpaceOnUse"><circle cx="2" cy="2" r="1.5" fill="white"/></pattern></defs>
        <rect width="100%" height="100%" fill="url(#dots2)"/>
      </svg>
    </div>
    <div class="relative max-w-5xl mx-auto px-4 sm:px-6">
      <div class="grid md:grid-cols-2 gap-16 items-center">
        <div>
          <p class="text-utopia-orange text-xs font-bold uppercase tracking-widest mb-5">Utopía Animal</p>
          <h2 class="text-4xl sm:text-5xl font-extrabold text-white leading-tight mb-6">
            Más que una veterinaria.<br/>
            <span class="text-utopia-400">Un proyecto de ciudad.</span>
          </h2>
          <p class="text-utopia-300 leading-relaxed mb-6">
            Fundamos Utopía Animal con la convicción de que el bienestar de los animales es un indicador del desarrollo humano de una sociedad. Lo que hacemos no es un negocio, es un proyecto de cambio cultural.
          </p>
          <p class="text-utopia-300 leading-relaxed mb-8">
            Por eso la veterinaria cobra precios justos. Por eso el refugio no cobra adopciones. Por eso educamos. Porque creemos que una Medellín que cuida bien a sus animales es una ciudad más humana para todos.
          </p>
          <a href="/nosotros" class="inline-flex items-center gap-2 bg-utopia-500 hover:bg-utopia-400 text-white font-bold px-6 py-3 rounded-xl transition-colors text-sm">
            Conocer Utopía Animal →
          </a>
        </div>
        <div class="space-y-4">
          {[
            { icon: '🌱', title: 'Propósito, no lucro', desc: 'Reinvertimos todo en bienestar animal. Una fundación respalda jurídicamente el ecosistema, tras bambalinas.' },
            { icon: '🩺', title: 'Veterinaria humanizada', desc: 'Medicina preventiva, trato cercano y precios justos. Los tutores deben entender lo que le pasa a su compañero.' },
            { icon: '🐾', title: 'Rescate y adopción', desc: 'Elim · Refugio Animal es el brazo de rescate, rehabilitación y adopción responsable, con voz animalista.' },
            { icon: '📚', title: 'Educación continua', desc: 'Blog, comunidad y redes. Porque un tutor informado es el mejor hogar que un animal puede tener.' },
          ].map(({ icon, title, desc }) => (
            <div class="flex items-start gap-4 bg-utopia-900/50 rounded-2xl p-5 border border-utopia-800">
              <span class="text-2xl shrink-0">{icon}</span>
              <div>
                <p class="font-bold text-white text-sm mb-1">{title}</p>
                <p class="text-utopia-400 text-xs leading-relaxed">{desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- REFUGIO ELIM - ÉNFASIS SECUNDARIO -->
  <section class="bg-gray-50 py-24 border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div class="order-2 lg:order-1 bg-elim-950 rounded-3xl p-8 text-white">
          <p class="text-elim-400 text-xs font-bold uppercase tracking-widest mb-4">Sobre Elim</p>
          <h3 class="text-2xl font-extrabold mb-4">Un movimiento animalista nacido del rescate.</h3>
          <p class="text-elim-300 leading-relaxed mb-6 text-sm">
            Elim comenzó antes que la veterinaria, como respuesta directa a la crisis de gatos callejeros en Medellín. Hoy es el brazo de rescate y adopción de Utopía Animal, con voz animalista, ecologista y activista.
          </p>
          <div class="grid grid-cols-2 gap-3 mb-6">
            {['Red de hogares temporales', 'Jornadas de esterilización', 'Rescate y rehabilitación', 'Comunidad activa'].map(s => (
              <div class="bg-elim-900 rounded-xl p-3 text-center text-xs text-elim-300 font-medium">{s}</div>
            ))}
          </div>
          <div class="flex flex-wrap gap-3">
            <a href="/refugio" class="inline-flex items-center gap-2 bg-elim-600 hover:bg-elim-500 text-white font-bold px-6 py-3 rounded-xl transition-colors text-sm">
              Conocer el refugio →
            </a>
            <a href="/refugio/adoptar/" class="inline-flex items-center gap-2 bg-white hover:bg-elim-50 text-elim-700 font-semibold px-6 py-3 rounded-xl transition-colors text-sm border border-elim-300">
              🐱 Adoptar un gato
            </a>
          </div>
        </div>
        <div class="order-1 lg:order-2">
          <div class="flex items-center gap-3 mb-5">
            <img src="/logo-elim.png" alt="Elim Refugio Animal" class="w-12 h-12 object-contain" loading="lazy"/>
            <span class="text-xs font-bold text-elim-700 uppercase tracking-widest">Elim Refugio Animal</span>
          </div>
          <h2 class="text-4xl font-extrabold text-gray-900 leading-tight mb-6">
            Cada gato callejero<br/>merece una segunda<br/>oportunidad.
          </h2>
          <p class="text-gray-600 leading-relaxed mb-5">
            No resolvemos el problema solo rescatando más gatos. Lo resolvemos cambiando la cultura: educando, esterilizando y construyendo una red humana que sostenga el bienestar animal.
          </p>
          <p class="text-gray-500 text-sm leading-relaxed">
            Si quieres ser parte como hogar temporal, voluntario o donante, escríbenos. Queremos conocerte.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- BLOG -->
  {posts.length > 0 && (
  <section class="bg-white py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="flex items-end justify-between mb-12">
        <div>
          <p class="text-xs font-bold text-utopia-500 uppercase tracking-widest mb-2">Blog · Bienestar Animal</p>
          <h2 class="text-3xl sm:text-4xl font-extrabold text-gray-900">Aprende a cuidar mejor.</h2>
          <p class="text-gray-500 mt-2 max-w-lg text-sm">Artículos sobre salud, comportamiento y bienestar para tutores de perros y gatos.</p>
        </div>
        <a href="/blog" class="hidden sm:flex items-center gap-1 text-sm font-semibold text-utopia-600 hover:text-utopia-800 transition-colors group">
          Ver todos
          <svg class="w-4 h-4 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {posts.map((post) => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            category={post.data.category}
            slug={post.slug}
          />
        ))}
      </div>
    </div>
  </section>
  )}

  <!-- CTA FINAL -->
  <section class="bg-gray-50 py-20 border-t border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="grid md:grid-cols-2 gap-6">
        <div class="bg-utopia-500 rounded-2xl p-8 text-white flex flex-col justify-between min-h-[200px]">
          <div>
            <p class="text-utopia-200 text-xs font-bold uppercase tracking-widest mb-2">Veterinaria · Av Guayabal</p>
            <h3 class="text-2xl font-extrabold mb-3">¿Tu compañero necesita atención?</h3>
            <p class="text-utopia-100 text-sm leading-relaxed mb-6">Lun–Sáb · 9:30am–6:00pm · Urgencias en horario · Precios justos</p>
          </div>
          <a href="https://api.whatsapp.com/send?phone=573215308188&text=Hola,%20quiero%20agendar%20una%20cita%20en%20Utop%C3%ADa%20Animal%20Vet"
            target="_blank" rel="noopener"
            class="self-start inline-flex items-center gap-2 bg-white text-utopia-600 font-bold px-6 py-3 rounded-xl text-sm hover:bg-utopia-50 transition-colors">
            💬 Agendar por WhatsApp
          </a>
        </div>
        <div class="bg-elim-800 rounded-2xl p-8 text-white flex flex-col justify-between min-h-[200px]">
          <div>
            <p class="text-elim-300 text-xs font-bold uppercase tracking-widest mb-2">Refugio Elim</p>
            <h3 class="text-2xl font-extrabold mb-3">¿Quieres ser parte del cambio?</h3>
            <p class="text-elim-200 text-sm leading-relaxed mb-6">Hogar temporal, donación, difusión o jornadas de esterilización. Cada acción suma.</p>
          </div>
          <a href="/apoya"
            class="self-start inline-flex items-center gap-2 bg-white text-elim-700 font-bold px-6 py-3 rounded-xl text-sm hover:bg-elim-50 transition-colors">
            Ver cómo apoyar →
          </a>
        </div>
      </div>
    </div>
  </section>

</Layout>
