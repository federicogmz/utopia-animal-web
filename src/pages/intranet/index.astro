---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Centro de Control · Adopciones Elim" brand="parent">
  <section class="bg-gray-50 min-h-screen py-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between mb-6 gap-4">
        <div>
          <h1 class="text-3xl font-extrabold text-gray-900">Centro de Control · Adopciones</h1>
          <p class="text-gray-500 mt-1" id="userBanner">Cargando sesión…</p>
        </div>
        <div class="flex items-center gap-3">
          <a href="/intranet/adopciones" class="inline-flex items-center gap-2 bg-elim-600 text-white px-4 py-2 rounded-xl text-sm font-semibold hover:bg-elim-500 transition-colors">🐱 Adopciones</a>
          <button id="btnRefresh" class="inline-flex items-center gap-2 bg-white border border-gray-200 px-4 py-2 rounded-xl text-sm font-semibold text-gray-700 hover:bg-gray-50 transition-colors">🔄 Actualizar</button>
          <button id="btnLogout" class="inline-flex items-center gap-2 bg-red-50 text-red-700 border border-red-100 px-4 py-2 rounded-xl text-sm font-semibold hover:bg-red-100 transition-colors">Cerrar Sesión</button>
        </div>
      </div>

      <div class="grid grid-cols-3 md:grid-cols-7 gap-3 mb-6" id="pipelineStats"></div>

      <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-4 mb-6 flex flex-col lg:flex-row gap-3 lg:items-center">
        <label id="misPendientesWrap" class="hidden items-center gap-2 cursor-pointer select-none bg-utopia-50 border border-utopia-200 rounded-xl px-4 py-2.5">
          <input type="checkbox" id="filterMine" class="rounded text-utopia-600 focus:ring-utopia-500" />
          <span class="text-sm font-bold text-utopia-800" id="filterMineLabel">Solo mis pendientes</span>
        </label>
        <input id="searchInput" type="text" placeholder="Buscar por nombre, correo, teléfono o ciudad..."
          class="flex-1 rounded-xl border border-gray-200 px-4 py-2.5 text-sm focus:ring-utopia-500 focus:border-utopia-500" />
        <select id="filterEtapa" class="rounded-xl border border-gray-200 px-4 py-2.5 text-sm focus:ring-utopia-500 focus:border-utopia-500">
          <option value="">Todas las etapas</option>
          <option value="recepcion">📥 Pendiente IA</option>
          <option value="filtro">🔎 Filtro inicial</option>
          <option value="concepto">📝 Pendiente mi concepto</option>
          <option value="entrevista">🎙️ Concepto de Laura</option>
          <option value="entrega">🤝 Entrega (rescatista)</option>
          <option value="completada">✅ Completada</option>
          <option value="rechazada">⛔ Rechazada</option>
        </select>
        <select id="filterReco" class="rounded-xl border border-gray-200 px-4 py-2.5 text-sm focus:ring-utopia-500 focus:border-utopia-500">
          <option value="">Toda recomendación IA</option>
          <option value="avanzar">✅ Avanzar</option>
          <option value="revisar">🟡 Revisar</option>
          <option value="descartar">⛔ Descartar</option>
          <option value="__none__">Sin evaluar</option>
        </select>
      </div>

      <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full text-left text-sm">
            <thead class="bg-gray-50 border-b border-gray-100">
              <tr>
                <th class="px-5 py-4 font-bold text-gray-700">ID / Fecha</th>
                <th class="px-5 py-4 font-bold text-gray-700">Solicitante</th>
                <th class="px-5 py-4 font-bold text-gray-700">Zona</th>
                <th class="px-5 py-4 font-bold text-gray-700">IA</th>
                <th class="px-5 py-4 font-bold text-gray-700">Etapa</th>
                <th class="px-5 py-4 font-bold text-gray-700 text-right">Acciones</th>
              </tr>
            </thead>
            <tbody id="tableBody" class="divide-y divide-gray-50">
              <tr><td colspan="6" class="px-6 py-12 text-center text-gray-500"><div class="animate-pulse">Cargando solicitudes...</div></td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <div id="modalDetail" class="hidden fixed inset-0 bg-gray-900/50 backdrop-blur-sm z-50 flex items-center justify-center p-4">
    <div class="bg-white w-full max-w-5xl max-h-[92vh] rounded-3xl shadow-2xl overflow-hidden flex flex-col">
      <div class="px-8 py-5 border-b border-gray-100 flex items-center justify-between bg-white">
        <h2 class="text-xl font-bold text-gray-900" id="modalTitle">Detalle de Solicitud</h2>
        <button id="btnCloseModal" title="Cerrar sin guardar" class="text-gray-400 hover:text-gray-600 p-2">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>
      <div class="p-8 overflow-y-auto flex-1 bg-gray-50" id="modalContent"></div>
      <div class="px-8 py-5 border-t border-gray-100 bg-white flex justify-between items-center gap-3">
        <span id="modalSaveStatus" class="text-sm text-gray-400"></span>
        <button id="btnSaveModal" class="px-6 py-2.5 rounded-xl bg-utopia-600 text-white font-bold hover:bg-utopia-700 transition-colors shadow-lg shadow-utopia-900/20">Guardar y cerrar</button>
      </div>
    </div>
  </div>
</Layout>

<script is:inline>
  let solicitudes = [];
  let currentId = null;
  let me = { user: '', nombre: '', rol: 'admin', etapa_responsable: null };

  // ── Etapas del flujo ──
  const ETAPAS = {
    recepcion:  { label: 'Pendiente evaluación IA', short: 'Pend. IA',     icon: '📥', badge: 'bg-gray-100 text-gray-700',   bar: 'bg-gray-400',   owner: 'IA' },
    filtro:     { label: 'Filtro inicial',          short: 'Filtro',       icon: '🔎', badge: 'bg-indigo-100 text-indigo-700', bar: 'bg-indigo-500', owner: 'Federico Gómez' },
    concepto:   { label: 'Pendiente de mi concepto', short: 'Mi concepto', icon: '📝', badge: 'bg-blue-100 text-blue-700',   bar: 'bg-blue-500',   owner: 'Federico Gómez' },
    entrevista: { label: 'Concepto de Laura',        short: 'Entrevista',  icon: '🎙️', badge: 'bg-amber-100 text-amber-800', bar: 'bg-amber-500',  owner: 'Laura López' },
    entrega:    { label: 'Entrega (rescatista)',     short: 'Entrega',     icon: '🤝', badge: 'bg-teal-100 text-teal-700',   bar: 'bg-teal-500',   owner: 'Rescatista' },
    completada: { label: 'Completada',               short: 'Completada',  icon: '✅', badge: 'bg-green-100 text-green-700', bar: 'bg-green-500',  owner: '—' },
    rechazada:  { label: 'Rechazada',                short: 'Rechazada',   icon: '⛔', badge: 'bg-red-100 text-red-700',     bar: 'bg-red-500',    owner: '—' },
  };
  const PIPELINE = ['recepcion', 'filtro', 'concepto', 'entrevista', 'entrega', 'completada'];
  const ORDER = { recepcion: 0, filtro: 1, concepto: 2, entrevista: 3, entrega: 4, completada: 5 };
  function etapaOf(s) { return ETAPAS[s.etapa] ? s.etapa : 'recepcion'; }
  function etapaMeta(e) { return ETAPAS[e] || ETAPAS.recepcion; }
  const esFederico = () => ['filtro', 'concepto', 'contacto'].includes(me.etapa_responsable);
  const esLaura = () => me.etapa_responsable === 'entrevista';

  // ── Cruce con zonas de alto abandono del Valle de Aburrá (red flag de entrada) ──
  const ZONAS_RIESGO = [
    { comuna: 'Comuna 4 · Aranjuez',     kw: ['aranjuez','aranjues','moravia','berlin','san isidro','bermejal','palermo','miranda','la piñuela','la pinuela'] },
    { comuna: 'Comuna 7 · Robledo',      kw: ['robledo','aures','pajarito','cucaracho','bello horizonte','san german','pilarica','el diamante','villa flora','la pola'] },
    { comuna: 'Comuna 3 · Manrique',     kw: ['manrique','versalles','las granjas','la salle','campo valdes','santa ines','la cruz','la honda','carambolas'] },
    { comuna: 'Comuna 1 · Popular',      kw: ['popular','santo domingo','granizal','moscu','villa guadalupe','aldea pablo vi','la avanzada','carpinelo'] },
    { comuna: 'San Antonio de Prado',    kw: ['san antonio de prado'] },
    { comuna: 'Comuna 10 · La Candelaria', kw: ['corazon de jesus','san benito','guayaquil','perpetuo socorro'] },
  ];
  function norm(s) { return String(s || '').toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, ''); }
  function zonaRiesgo(barrio, ciudad) {
    if (!norm(ciudad).includes('medellin')) return null;
    const b = norm(barrio);
    for (const z of ZONAS_RIESGO) for (const k of z.kw) if (b.includes(k)) return z.comuna;
    return null;
  }

  function esMiPendiente(s) {
    const e = etapaOf(s);
    if (esFederico()) return e === 'filtro' || e === 'concepto';
    if (esLaura()) return e === 'entrevista';
    return e !== 'completada' && e !== 'rechazada';
  }

  function esc(v) {
    if (v === null || v === undefined) return '';
    return String(v).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;');
  }
  function parseArr(v) {
    if (Array.isArray(v)) return v;
    if (!v) return [];
    try { const p = JSON.parse(v); return Array.isArray(p) ? p : [p]; } catch (e) { return [String(v)]; }
  }
  function fmtBool(v) {
    if (v === 1 || v === '1' || v === true) return '✅ Sí';
    if (v === 0 || v === '0' || v === false) return '❌ No';
    return '—';
  }
  function fmtDate(v) {
    if (!v) return '—';
    try { return new Date(v.replace(' ', 'T') + 'Z').toLocaleString('es-CO'); } catch (e) { return esc(v); }
  }
  function recoMeta(reco) {
    return {
      avanzar:   { label: 'Avanzar', icon: '✅', badge: 'bg-green-100 text-green-800', bar: 'bg-green-500' },
      revisar:   { label: 'Revisar', icon: '🟡', badge: 'bg-amber-100 text-amber-800', bar: 'bg-amber-500' },
      descartar: { label: 'Descartar', icon: '⛔', badge: 'bg-red-100 text-red-800', bar: 'bg-red-500' },
    }[reco] || { label: 'Sin evaluar', icon: '⏳', badge: 'bg-gray-100 text-gray-600', bar: 'bg-gray-300' };
  }
  function scoreColor(score) {
    if (score === null || score === undefined || score === '') return 'text-gray-400';
    const n = Number(score);
    if (n >= 80) return 'text-green-600';
    if (n >= 60) return 'text-amber-600';
    return 'text-red-600';
  }
  function waPhone(t) {
    let d = String(t || '').replace(/\D/g, '');
    if (d.length === 10 && d.startsWith('3')) d = '57' + d;
    return d;
  }

  function buildWaMessage(s) {
    const first = (s.nombre_completo || '').trim().split(/\s+/)[0] || '';
    if (s.recomendacion === 'descartar') {
      return [
        `Hola ${first} 👋, te escribimos del equipo de Elim Refugio Animal.`, '',
        'Antes que todo, gracias de corazón por tu interés en adoptar y por el tiempo que dedicaste a la solicitud. 💛', '',
        'Revisamos tu caso con mucho cuidado y, en esta ocasión, no podremos continuar con el proceso de adopción. Esta decisión busca siempre el bienestar y la seguridad del gato a largo plazo, y no es un juicio sobre ti como persona.', '',
        'Si quieres, podemos contarte qué aspectos tener en cuenta para una futura adopción, y también puedes apoyarnos de otras formas: difundiendo, esterilizando o como hogar temporal.', '',
        'Gracias por tu comprensión y por querer darle un hogar a un gatito. 🐱', 'Equipo Elim · Utopía Animal',
      ].join('\n');
    }
    const preguntas = parseArr(s.preguntas_followup);
    const lines = [];
    lines.push(`Hola ${first} 👋, te escribimos del equipo de Elim Refugio Animal.`); lines.push('');
    lines.push('¡Gracias por tu solicitud de adopción! Nos gustó tu perfil y queremos avanzar al siguiente paso. Para continuar nos ayudarías con lo siguiente:'); lines.push('');
    if (preguntas.length) preguntas.forEach((q, i) => lines.push(`${i + 1}. ${q}`));
    else lines.push('1. Cuéntanos un poco más sobre tu hogar y tu rutina diaria con el gato.');
    lines.push('');
    lines.push('Sobre todo, ¿podrías enviarnos un *video corto de tu hogar*? Idealmente mostrando ventanas y balcones (y si tienen mallas o protección) y el espacio donde estaría el gato 🐱'); lines.push('');
    lines.push('Quedamos atentos. ¡Gracias por querer adoptar de forma responsable! 💛'); lines.push('Equipo Elim · Utopía Animal');
    return lines.join('\n');
  }

  window.sendWhatsApp = function() {
    const s = solicitudes.find(x => x.id === currentId);
    if (!s) return;
    const phone = waPhone(s.telefono);
    if (!phone || phone.length < 10) { alert('Esta solicitud no tiene un teléfono válido.'); return; }
    const ta = document.getElementById('waMessage');
    const text = ta ? ta.value : buildWaMessage(s);
    window.open(`https://wa.me/${phone}?text=${encodeURIComponent(text)}`, '_blank', 'noopener');
  };

  window.concretarAdopcion = function() {
    const s = solicitudes.find(x => x.id === currentId);
    if (!s) return;
    const p = new URLSearchParams({ from: String(s.id), adoptante: s.nombre_completo || '', tel: s.telefono || '' });
    window.location.href = '/intranet/adopciones?' + p.toString();
  };

  window.avanzarEtapa = function(nuevaEtapa) {
    const sel = document.getElementById('editEtapa');
    if (sel) sel.value = nuevaEtapa; else window.__overrideEtapa = nuevaEtapa;
    document.getElementById('btnSaveModal').click();
  };

  // Rechazo con motivo obligatorio.
  window.pedirMotivo = function() {
    const box = document.getElementById('accionesBox');
    if (!box) return;
    box.innerHTML = `
      <div class="w-full bg-red-50 border border-red-200 rounded-xl p-4">
        <label class="text-xs font-bold text-red-700 uppercase mb-1 block">Motivo del rechazo (obligatorio)</label>
        <textarea id="motivoRechazoInput" rows="2" class="w-full rounded-xl border-red-200 text-sm focus:ring-red-500 focus:border-red-500" placeholder="Explica brevemente por qué se rechaza esta solicitud..."></textarea>
        <div class="flex gap-3 mt-3">
          <button onclick="confirmarRechazo()" class="bg-red-600 hover:bg-red-700 text-white font-bold px-5 py-2.5 rounded-xl text-sm">Confirmar rechazo</button>
          <button onclick="openDetail(currentId)" class="border border-gray-200 text-gray-700 font-semibold px-5 py-2.5 rounded-xl text-sm">Cancelar</button>
        </div>
      </div>`;
    const t = document.getElementById('motivoRechazoInput'); if (t) t.focus();
  };
  window.confirmarRechazo = function() {
    const el = document.getElementById('motivoRechazoInput');
    const m = el ? el.value.trim() : '';
    if (!m) { alert('Escribe el motivo del rechazo.'); return; }
    window.__motivoRechazo = m;
    window.__overrideEtapa = 'rechazada';
    const sel = document.getElementById('editEtapa'); if (sel) sel.value = 'rechazada';
    document.getElementById('btnSaveModal').click();
  };

  window.exportarPdf = function() {
    const s = solicitudes.find(x => x.id === currentId);
    if (!s) return;
    const buenas = parseArr(s.senales_buenas), alertas = parseArr(s.senales_alerta), fu = parseArr(s.preguntas_followup), comp = parseArr(s.compromisos_aceptados);
    const rm = recoMeta(s.recomendacion); const em = etapaMeta(etapaOf(s));
    const li = a => a.length ? '<ul>' + a.map(x => `<li>${esc(x)}</li>`).join('') + '</ul>' : '<p>—</p>';
    const f = (l, v) => `<tr><td class="k">${esc(l)}</td><td>${esc(v == null || v === '' ? '—' : v)}</td></tr>`;
    const fb = (l, v) => `<tr><td class="k">${esc(l)}</td><td>${fmtBool(v)}</td></tr>`;
    const html = `<!doctype html><html lang="es"><head><meta charset="utf-8"><title>Solicitud #${s.id} · ${esc(s.nombre_completo)}</title>
      <style>body{font-family:-apple-system,Segoe UI,Roboto,sans-serif;color:#1f2937;margin:32px;font-size:12px;line-height:1.5}
      h1{font-size:20px;margin:0 0 2px} h2{font-size:13px;text-transform:uppercase;letter-spacing:.05em;color:#6d28d9;border-bottom:1px solid #eee;padding-bottom:4px;margin:18px 0 8px}
      table{width:100%;border-collapse:collapse;margin-bottom:6px} td{padding:3px 6px;vertical-align:top;border-bottom:1px solid #f3f4f6}
      td.k{color:#6b7280;width:38%} ul{margin:4px 0;padding-left:18px} .badge{display:inline-block;padding:2px 10px;border-radius:99px;background:#ede9fe;color:#5b21b6;font-weight:700;font-size:11px}
      .muted{color:#9ca3af;font-size:11px} .score{font-size:22px;font-weight:800}</style></head><body>
      <h1>Solicitud #${esc(s.id)} · ${esc(s.nombre_completo)}</h1>
      <p class="muted">Enviada: ${esc(fmtDate(s.fecha_envio))} · Etapa: ${esc(em.label)}${s.etapa==='rechazada'&&s.motivo_rechazo?` · Motivo: ${esc(s.motivo_rechazo)}`:''}</p>
      <h2>Evaluación IA</h2>
      <p><span class="score">${(s.score==null||s.score==='')?'—':Math.round(Number(s.score))}</span>/100 &nbsp; <span class="badge">${rm.icon} ${rm.label}</span></p>
      <b>Señales buenas</b>${li(buenas)}<b>Señales de alerta</b>${li(alertas)}<b>Preguntas de seguimiento</b>${li(fu)}
      ${s.notas_ia ? `<p><b>Notas IA:</b> ${esc(s.notas_ia)}</p>` : ''}
      <h2>Datos personales</h2><table>${f('Cédula',s.cedula)}${f('Edad',s.edad)}${f('Ocupación',s.ocupacion)}${f('Teléfono',s.telefono)}${f('Correo',s.correo)}${f('Dirección',s.direccion)}${f('Ciudad/Barrio',(s.ciudad||'—')+' / '+(s.barrio||'—'))}${f('Estrato',s.estrato)}</table>
      <h2>Vivienda y hogar</h2><table>${f('Tipo de vivienda',s.tipo_vivienda)}${f('Situación',s.situacion_habitacional)}${fb('Mallas de seguridad',s.mallas_seguridad)}${f('Adultos en casa',s.adultos_casa)}${f('Niños',s.ninos_edades)}${fb('Todos de acuerdo',s.todos_de_acuerdo)}${fb('Otras mascotas',s.tiene_otras_mascotas)}${f('Detalle mascotas',s.otras_mascotas_tipo)}</table>
      <h2>Motivación y planes</h2><table>${f('¿Por qué adoptar?',s.por_que_adoptar)}${f('Género preferido',s.genero_preferido)}${f('Edad del gato',s.edad_estimada_gatito)}${f('Responsable gastos',s.responsable_gastos)}${f('Plan dificultad económica',s.plan_dificultad_economica)}${f('Plan comportamiento',s.plan_comportamiento)}${f('Plan enfermedad',s.plan_enfermedad)}${f('Plan vacaciones',s.plan_vacaciones)}</table>
      <h2>Gestión por etapas</h2><table>${f('Etapa actual',em.label)}${f('Mallas (gestión)',s.mallas_estado)}${fb('Video recibido',s.video_recibido)}${f('Video viable',s.video_viable)}${f('Notas video',s.video_notas)}${f('Mi concepto (Federico)',s.observaciones_contacto)}${f('Concepto entrevista (Laura)',s.entrevista_notas)}${f('Rescatista asignado',s.rescatista_asignado)}${f('Motivo de rechazo',s.motivo_rechazo)}${f('Notas humanas',s.notas_humanas)}</table>
      <script>window.onload=function(){window.print()}<\/script></body></html>`;
    const w = window.open('', '_blank');
    if (w) { w.document.write(html); w.document.close(); }
  };

  function roleLabel() {
    if (esFederico()) return 'Filtro y concepto inicial';
    if (esLaura()) return 'Entrevista final';
    return me.rol === 'admin' ? 'Administrador' : me.rol;
  }

  async function loadMe() {
    try {
      const res = await fetch('/api/admin/whoami');
      if (res.status === 401) { window.location.href = '/intranet/login'; return; }
      const j = await res.json();
      if (j.ok) {
        me = j;
        document.getElementById('userBanner').innerHTML = `Hola <b class="text-gray-900">${esc(me.nombre)}</b> · <span class="text-utopia-700 font-semibold">${esc(roleLabel())}</span>`;
        if (esFederico() || esLaura()) {
          const wrap = document.getElementById('misPendientesWrap');
          wrap.classList.remove('hidden'); wrap.classList.add('flex');
          document.getElementById('filterMine').checked = true;
          document.getElementById('filterMineLabel').textContent = esFederico() ? 'Solo mis pendientes (filtro / concepto)' : 'Solo mis pendientes (entrevista)';
        }
      }
    } catch (e) { console.error(e); }
  }

  async function loadData() {
    try {
      const res = await fetch('/api/admin/solicitudes');
      if (res.status === 401) { window.location.href = '/intranet/login'; return; }
      const json = await res.json();
      if (json.ok) { solicitudes = json.solicitudes || []; renderStats(); renderTable(); }
    } catch (err) { console.error(err); alert('Error cargando datos'); }
  }

  function renderStats() {
    const counts = {}; PIPELINE.concat(['rechazada']).forEach(e => counts[e] = 0);
    solicitudes.forEach(s => { const e = etapaOf(s); counts[e] = (counts[e] || 0) + 1; });
    const order = ['recepcion','filtro','concepto','entrevista','entrega','completada','rechazada'];
    const mineStages = esFederico() ? ['filtro','concepto'] : esLaura() ? ['entrevista'] : [];
    const cards = order.map(e => {
      const m = ETAPAS[e];
      const mine = mineStages.includes(e);
      return `<button data-etapa="${e}" class="statCard text-left bg-white p-4 rounded-2xl shadow-sm border ${mine ? 'border-utopia-300 ring-1 ring-utopia-200' : 'border-gray-100'} hover:shadow-md transition-shadow">
        <p class="text-[11px] font-bold text-gray-500 uppercase tracking-wider mb-1">${m.icon} ${m.short}</p>
        <p class="text-2xl font-black text-gray-900">${counts[e] || 0}</p></button>`;
    }).join('');
    document.getElementById('pipelineStats').innerHTML = cards;
    document.querySelectorAll('.statCard').forEach(b => b.onclick = () => {
      document.getElementById('filterEtapa').value = b.dataset.etapa;
      document.getElementById('filterMine').checked = false;
      renderTable();
    });
  }

  function getFiltered() {
    const q = (document.getElementById('searchInput').value || '').toLowerCase().trim();
    const fEtapa = document.getElementById('filterEtapa').value;
    const fr = document.getElementById('filterReco').value;
    const mine = document.getElementById('filterMine').checked;
    return solicitudes.filter(s => {
      if (mine && !esMiPendiente(s)) return false;
      if (fEtapa && etapaOf(s) !== fEtapa) return false;
      if (fr === '__none__' && s.evaluado_at) return false;
      else if (fr && fr !== '__none__' && s.recomendacion !== fr) return false;
      if (q) {
        const hay = `${s.nombre_completo || ''} ${s.correo || ''} ${s.telefono || ''} ${s.ciudad || ''} ${s.barrio || ''}`.toLowerCase();
        if (!hay.includes(q)) return false;
      }
      return true;
    });
  }

  function renderTable() {
    const tbody = document.getElementById('tableBody');
    const rows = getFiltered();
    if (rows.length === 0) { tbody.innerHTML = '<tr><td colspan="6" class="px-6 py-12 text-center text-gray-500">No hay solicitudes que coincidan.</td></tr>'; return; }
    tbody.innerHTML = rows.map(s => {
      const rm = recoMeta(s.recomendacion);
      const em = etapaMeta(etapaOf(s));
      const mine = esMiPendiente(s);
      const zona = zonaRiesgo(s.barrio, s.ciudad);
      const scoreTxt = (s.score === null || s.score === undefined || s.score === '') ? '—' : Math.round(Number(s.score));
      return `
      <tr class="hover:bg-gray-50 transition-colors ${mine ? 'bg-utopia-50/40' : ''}">
        <td class="px-5 py-4 align-top">${mine ? '<span class="inline-block w-1.5 h-1.5 rounded-full bg-utopia-500 mr-1 align-middle" title="Te corresponde"></span>' : ''}<span class="font-bold text-gray-900">#${esc(s.id)}</span><div class="text-xs text-gray-500">${esc(new Date(s.fecha_envio).toLocaleDateString())}</div></td>
        <td class="px-5 py-4 align-top font-medium text-gray-900">${esc(s.nombre_completo)}<div class="text-xs font-normal text-gray-400">${esc(s.telefono)}</div></td>
        <td class="px-5 py-4 align-top text-gray-600">${esc(s.ciudad || '-')}<br/><span class="text-xs">${esc(s.barrio || '-')}</span>${zona ? `<div class="mt-1"><span class="px-2 py-0.5 rounded-full text-[10px] font-bold bg-red-100 text-red-700" title="${esc(zona)}">🚩 Zona alto abandono</span></div>` : ''}</td>
        <td class="px-5 py-4 align-top"><div class="flex items-center gap-2"><span class="font-black ${scoreColor(s.score)}">${scoreTxt}</span><span class="px-2 py-0.5 rounded-full text-[11px] font-bold ${rm.badge}">${rm.icon} ${rm.label}</span></div></td>
        <td class="px-5 py-4 align-top"><span class="px-2.5 py-1 rounded-full text-xs font-bold ${em.badge}">${em.icon} ${em.short}</span></td>
        <td class="px-5 py-4 align-top text-right"><button onclick="openDetail(${Number(s.id)})" class="text-utopia-600 font-bold hover:text-utopia-800 transition-colors whitespace-nowrap">Gestionar →</button></td>
      </tr>`;
    }).join('');
  }

  function row(label, value) { return `<dt class="text-gray-500">${esc(label)}:</dt> <dd class="text-gray-900 break-words">${esc(value === null || value === undefined || value === '' ? '—' : value)}</dd>`; }
  function boolRow(label, value) { return `<dt class="text-gray-500">${esc(label)}:</dt> <dd class="text-gray-900 font-medium">${fmtBool(value)}</dd>`; }
  function longField(label, value) { return `<div><p class="text-gray-500 mb-1">${esc(label)}</p><p class="text-gray-900 p-3 bg-white rounded-lg border border-gray-200 whitespace-pre-wrap">${esc(value || '—')}</p></div>`; }
  function section(title, inner) { return `<div class="bg-white rounded-xl border border-gray-200 p-5 mb-5"><h3 class="text-sm font-bold text-gray-900 uppercase tracking-wide border-b border-gray-100 pb-2 mb-4">${esc(title)}</h3>${inner}</div>`; }
  function dl(inner) { return `<dl class="grid grid-cols-2 gap-x-4 gap-y-2.5 text-sm">${inner}</dl>`; }
  function chips(arr, cls) { if (!arr.length) return '<span class="text-gray-400 text-sm">—</span>'; return arr.map(x => `<li class="flex gap-2"><span>${cls.icon}</span><span>${esc(x)}</span></li>`).join(''); }
  function roRow(label, value) { return `<div class="flex justify-between gap-3 py-1.5 border-b border-gray-50 last:border-0"><span class="text-gray-500 text-sm">${esc(label)}</span><span class="text-gray-900 text-sm font-medium text-right">${esc(value === null || value === undefined || value === '' ? '—' : value)}</span></div>`; }

  function buildStepper(cur, motivo) {
    if (cur === 'rechazada') return `<div class="mb-6 p-4 bg-red-50 border border-red-200 rounded-2xl"><div class="flex items-center gap-2"><span class="text-lg">⛔</span><span class="font-bold text-red-700">Solicitud rechazada</span></div>${motivo ? `<p class="text-sm text-red-700 mt-1 pl-7"><b>Motivo:</b> ${esc(motivo)}</p>` : ''}</div>`;
    const curStep = ORDER[cur];
    const items = PIPELINE.map((e, i) => {
      const m = ETAPAS[e];
      const done = i < curStep, active = i === curStep;
      const dot = active ? `${m.bar} text-white ring-4 ring-offset-1 ring-gray-100` : done ? 'bg-green-500 text-white' : 'bg-gray-200 text-gray-400';
      return `<div class="flex-1 flex flex-col items-center text-center"><div class="w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold ${dot}">${done ? '✓' : i + 1}</div><span class="text-[10px] mt-1 font-semibold ${active ? 'text-gray-900' : done ? 'text-green-600' : 'text-gray-400'}">${m.icon} ${m.short}</span></div>`;
    }).join('<div class="flex-1 h-0.5 bg-gray-200 mt-4"></div>');
    return `<div class="flex items-start mb-6 px-2">${items}</div>`;
  }

  function buildAcciones(s) {
    const e = etapaOf(s);
    const btn = (label, fn, cls) => `<button onclick="${fn}" class="inline-flex items-center gap-2 ${cls} font-bold px-5 py-2.5 rounded-xl text-sm transition-colors">${label}</button>`;
    const reject = btn('⛔ Rechazar', `pedirMotivo()`, 'bg-red-50 text-red-700 border border-red-200 hover:bg-red-100');
    if (e === 'recepcion') return `<span class="text-sm text-gray-500">Esperando evaluación de la IA. Al calificar, entrará al filtro inicial.</span>`;
    if (e === 'completada') return `<div class="flex items-center gap-2 text-green-700 font-bold"><span>✅</span> Adopción completada</div>`;
    let primary = '';
    if (e === 'filtro') primary = btn('📲 Contacté y pedí el video', `avanzarEtapa('concepto')`, 'bg-blue-600 hover:bg-blue-700 text-white shadow-lg shadow-blue-900/20');
    else if (e === 'concepto') primary = btn('🎙️ Dar mi concepto y pasar a entrevista', `avanzarEtapa('entrevista')`, 'bg-amber-500 hover:bg-amber-600 text-white shadow-lg shadow-amber-900/20');
    else if (e === 'entrevista') primary = btn('🤝 Aprobar y escalar a rescatista', `avanzarEtapa('entrega')`, 'bg-teal-600 hover:bg-teal-700 text-white shadow-lg shadow-teal-900/20');
    else if (e === 'entrega') return `<div class="flex flex-wrap items-center gap-3">${btn('🐱 Concretar adopción', `concretarAdopcion()`, 'bg-elim-600 hover:bg-elim-500 text-white shadow-lg shadow-elim-900/20')}</div>`;
    return `<div class="flex flex-wrap items-center gap-3">${primary}${reject}</div>`;
  }

  window.openDetail = function(id) {
    currentId = id;
    window.__overrideEtapa = null; window.__motivoRechazo = null;
    const s = solicitudes.find(x => x.id === id);
    if (!s) return;
    const cur = etapaOf(s); const em = etapaMeta(cur); const curOrder = ORDER[cur] ?? 0;
    const evaluada = !!s.evaluado_at;
    const zona = zonaRiesgo(s.barrio, s.ciudad);

    document.getElementById('modalTitle').innerHTML = `Solicitud #${esc(s.id)} · ${esc(s.nombre_completo)} <span class="ml-2 px-2.5 py-1 rounded-full text-xs font-bold ${em.badge}">${em.icon} ${em.label}</span>`;

    const compromisos = parseArr(s.compromisos_aceptados);
    const buenas = parseArr(s.senales_buenas);
    const alertas = parseArr(s.senales_alerta);
    const followups = parseArr(s.preguntas_followup);
    const rm = recoMeta(s.recomendacion);
    const scoreTxt = (s.score === null || s.score === undefined || s.score === '') ? '—' : Math.round(Number(s.score));

    const stepper = buildStepper(cur, s.motivo_rechazo);

    const zonaBanner = zona ? `<div class="bg-red-50 border-2 border-red-200 rounded-2xl p-4 mb-6 flex items-start gap-3"><span class="text-xl">🚩</span><div><p class="font-bold text-red-800 text-sm">Zona de alto abandono — ${esc(zona)}</p><p class="text-xs text-red-700 mt-0.5">Barrio en una de las zonas con mayor índice de abandono/maltrato del Valle de Aburrá. Red flag de entrada: exige verificación domiciliaria estricta antes de cualquier entrega.</p></div></div>` : '';

    const iaPanel = !evaluada ? `<div class="bg-gray-50 rounded-2xl border border-gray-200 p-6 mb-6 text-sm text-gray-500">⏳ Esta solicitud aún no ha sido evaluada por la IA. Al calificarse, entrará al filtro inicial.</div>` : `
      <div class="bg-gradient-to-br from-utopia-50 to-white rounded-2xl border border-utopia-100 p-6 mb-6">
        <div class="flex flex-wrap items-center justify-between gap-4 mb-5"><div class="flex items-center gap-3"><span class="text-xs font-bold text-utopia-700 uppercase tracking-widest">Evaluación IA</span><span class="px-3 py-1 rounded-full text-xs font-bold ${rm.badge}">${rm.icon} ${rm.label}</span></div><div class="text-right"><span class="text-3xl font-black ${scoreColor(s.score)}">${scoreTxt}</span><span class="text-gray-400 text-sm font-semibold">/100</span></div></div>
        <div class="w-full h-2 bg-gray-100 rounded-full overflow-hidden mb-5"><div class="h-full ${rm.bar}" style="width:${Math.max(0, Math.min(100, Number(s.score) || 0))}%"></div></div>
        <div class="grid md:grid-cols-2 gap-5"><div><p class="text-xs font-bold text-green-700 uppercase mb-2">Señales buenas</p><ul class="space-y-1.5 text-sm text-gray-700">${chips(buenas, { icon: '✅' })}</ul></div><div><p class="text-xs font-bold text-red-700 uppercase mb-2">Señales de alerta</p><ul class="space-y-1.5 text-sm text-gray-700">${chips(alertas, { icon: '⚠️' })}</ul></div></div>
        <div class="mt-5"><p class="text-xs font-bold text-blue-700 uppercase mb-2">Preguntas de seguimiento</p><ul class="space-y-1.5 text-sm text-gray-700">${chips(followups, { icon: '❓' })}</ul></div>
        ${s.notas_ia ? `<div class="mt-5 bg-white rounded-lg border border-gray-200 p-4"><p class="text-xs font-bold text-gray-500 uppercase mb-1">Notas IA</p><p class="text-sm text-gray-700 whitespace-pre-wrap">${esc(s.notas_ia)}</p></div>` : ''}
        <p class="text-xs text-gray-400 mt-4">Evaluado: ${fmtDate(s.evaluado_at)}</p>
      </div>`;

    // WhatsApp: solo en el FILTRO inicial (para pedir el video o cerrar amablemente). Desaparece al avanzar.
    const phoneFmt = waPhone(s.telefono);
    const esRechazo = s.recomendacion === 'descartar';
    const whatsapp = (cur === 'filtro') ? `
      <div class="bg-white rounded-2xl border-2 ${esRechazo ? 'border-red-200' : 'border-green-200'} p-6 mb-6">
        <div class="flex items-center justify-between mb-2"><h3 class="text-sm font-bold ${esRechazo ? 'text-red-800' : 'text-green-800'} uppercase tracking-wide">📲 ${esRechazo ? 'Mensaje de cierre (rechazo)' : 'Mensaje para pedir el video'}</h3><span class="text-xs text-gray-400">${phoneFmt ? '+' + esc(phoneFmt) : 'sin teléfono válido'}</span></div>
        <p class="text-xs text-gray-500 mb-3">${esRechazo ? 'La IA recomienda no continuar; este mensaje es para un cierre amable.' : 'La IA recomienda continuar: este mensaje pide el video del hogar.'} Tras enviarlo, marca abajo «Contacté y pedí el video». Este mensaje desaparece al avanzar.</p>
        <textarea id="waMessage" rows="10" class="w-full rounded-xl border-gray-200 text-sm focus:ring-green-500 focus:border-green-500">${esc(buildWaMessage(s))}</textarea>
        <div class="flex justify-end mt-3"><button onclick="sendWhatsApp()" class="inline-flex items-center gap-2 ${esRechazo ? 'bg-red-600 hover:bg-red-700' : 'bg-green-600 hover:bg-green-700'} text-white font-bold px-6 py-2.5 rounded-xl transition-colors shadow-lg">Abrir WhatsApp →</button></div>
      </div>` : '';

    const selOpt = (val, label, cur2) => `<option value="${val}" ${cur2 === val ? 'selected' : ''}>${label}</option>`;

    // ── Acciones + gestión general ──
    const gestion = `
      <div class="bg-white rounded-2xl border-2 border-utopia-200 p-6 mb-6">
        <div id="accionesBox" class="mb-5">${buildAcciones(s)}</div>
        <div class="border-t border-gray-100 pt-5"><label class="text-xs font-bold text-gray-500 uppercase mb-1 block">Asignado a</label><input id="editAsignado" type="text" value="${esc(s.asignado_a || '')}" placeholder="Responsable" class="w-full rounded-xl border-gray-200 text-sm focus:ring-utopia-500 focus:border-utopia-500" /></div>
        <div class="mt-4"><label class="text-xs font-bold text-gray-500 uppercase mb-1 block">Notas generales del equipo</label><textarea id="editNotas" rows="2" class="w-full rounded-xl border-gray-200 text-sm focus:ring-utopia-500 focus:border-utopia-500" placeholder="Seguimiento general...">${esc(s.notas_humanas || '')}</textarea></div>
        <div class="mt-4"><label class="text-xs font-bold text-gray-500 uppercase mb-1 block">Agregar nota al historial (opcional)</label><input id="editNotaHist" type="text" placeholder="Quedará registrada con tu nombre y la fecha" class="w-full rounded-xl border-gray-200 text-sm focus:ring-utopia-500 focus:border-utopia-500" /></div>
        <input type="hidden" id="editEtapa" value="${esc(cur)}" />
        <div class="mt-5"><button onclick="exportarPdf()" class="inline-flex items-center gap-2 bg-white border border-gray-200 hover:bg-gray-50 text-gray-700 font-semibold px-5 py-2.5 rounded-xl text-sm">📄 Exportar PDF</button></div>
      </div>`;

    // ── Bloque «Mi concepto» (Federico): video / mallas / observaciones ──
    let conceptoBlock;
    if (curOrder < ORDER.concepto) {
      conceptoBlock = `<div class="bg-gray-50 rounded-2xl border border-dashed border-gray-200 p-5 mb-6 text-sm text-gray-400">🔒 Mi concepto — se habilita cuando contactes y pidas el video.</div>`;
    } else if (cur === 'concepto') {
      conceptoBlock = `
      <div class="bg-white rounded-2xl border-2 border-blue-300 ring-1 ring-blue-200 p-6 mb-6">
        <h3 class="text-sm font-bold text-blue-800 uppercase tracking-wide mb-1">📝 Mi concepto <span class="text-blue-500 font-normal normal-case">— en curso (Federico)</span></h3>
