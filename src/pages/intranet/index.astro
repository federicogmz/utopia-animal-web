    const mascotas = section('Otras mascotas', dl(boolRow('Tiene otras mascotas', s.tiene_otras_mascotas) + row('Tipo y cantidad', s.otras_mascotas_tipo) + boolRow('Esterilizadas', s.otras_esterilizadas) + row('Alimento', s.otras_alimento)) + (s.otras_anteriores ? `<div class="mt-3">${longField('Mascotas anteriores', s.otras_anteriores)}</div>` : ''));
    const hogar = section('Hogar y familia', dl(row('Adultos en casa', s.adultos_casa) + row('Edades de niños', s.ninos_edades) + boolRow('Todos de acuerdo', s.todos_de_acuerdo) + row('Quién no está de acuerdo', s.quien_no_de_acuerdo) + boolRow('Planes de mudanza', s.planes_mudanza) + row('Cuándo / a dónde', s.cuando_mudanza) + boolRow('Alguien alérgico', s.alguien_alergico) + row('Quién / severidad', s.quien_alergico)));
    const compromiso = section('Compromiso y donación', dl(row('Tipo de donación', s.donacion_tipo) + row('Monto (COP)', s.donacion_monto) + boolRow('Declaración final aceptada', s.declaracion_final)) + `<div class="mt-4"><p class="text-gray-500 text-sm mb-2">Compromisos aceptados:</p><ul class="text-sm text-gray-700 space-y-1">${chips(compromisos, { icon: '✔️' })}</ul></div>`);
    const mapQuery = [s.direccion, s.barrio, s.ciudad, 'Colombia'].filter(Boolean).join(', ');
    const mapa = mapQuery ? section('Ubicación', `<p class="text-sm text-gray-700 mb-2">${esc([s.direccion, s.barrio, s.ciudad].filter(Boolean).join(' · ') || '—')}</p><iframe width="100%" height="240" style="border:0;border-radius:12px" loading="lazy" referrerpolicy="no-referrer-when-downgrade" src="https://maps.google.com/maps?q=${encodeURIComponent(mapQuery)}&z=14&output=embed"></iframe>`) : '';

    document.getElementById('modalContent').innerHTML =
      stepper + zonaBanner + iaPanel + whatsapp + gestion + conceptoBlock + entrevistaBlock + timeline +
      `<div class="grid md:grid-cols-2 gap-x-5"><div>${personal}${vivienda}${mapa}${redes}${mascotas}</div><div>${motivacion}${planes}${hogar}${compromiso}</div></div>`;

    document.getElementById('modalSaveStatus').textContent = '';
    document.getElementById('modalDetail').classList.remove('hidden');
    document.body.style.overflow = 'hidden';
    loadTimeline(id);
  };

  async function loadTimeline(id) {
    try {
      const res = await fetch('/api/admin/historial?id=' + id);
      const j = await res.json();
      const box = document.getElementById('timelineContent');
      if (!box) return;
      if (!j.ok || !j.historial.length) { box.innerHTML = '<span class="text-gray-400">Sin movimientos registrados todavía.</span>'; return; }
      const items = j.historial.map(h => {
        let desc;
        if (h.accion === 'etapa') desc = `cambió la <b>etapa</b> a <b>${esc((ETAPAS[h.valor_nuevo]||{}).label || h.valor_nuevo)}</b>`;
        else if (h.accion === 'nota') desc = `dejó una nota: <span class="text-gray-700">"${esc(h.valor_nuevo)}"</span>`;
        else if (h.campo === 'motivo_rechazo') desc = `registró el <b>motivo de rechazo</b>: <span class="text-gray-700">"${esc(h.valor_nuevo)}"</span>`;
        else desc = `actualizó <b>${esc(h.campo)}</b>${h.valor_nuevo ? ` → <span class="text-gray-700">${esc(h.valor_nuevo)}</span>` : ''}`;
        const who = h.usuario === 'ia' ? '🤖 IA' : '👤 ' + esc(h.usuario_nombre || h.usuario);
        return `<li class="flex gap-3 pb-3 border-b border-gray-50 last:border-0"><div class="text-xs text-gray-400 whitespace-nowrap w-32 shrink-0">${fmtDate(h.created_at)}</div><div class="text-sm text-gray-600"><b class="text-gray-800">${who}</b> ${desc}</div></li>`;
      }).join('');
      document.getElementById('timelineBox').innerHTML = `<h3 class="text-sm font-bold text-gray-900 uppercase tracking-wide mb-4">🕘 Historial de cambios</h3><ul class="space-y-3">${items}</ul>`;
    } catch (e) { /* noop */ }
  }

  function closeModal() { document.getElementById('modalDetail').classList.add('hidden'); document.body.style.overflow = 'auto'; }
  document.getElementById('btnCloseModal').onclick = closeModal;

  document.getElementById('btnSaveModal').onclick = async () => {
    const btn = document.getElementById('btnSaveModal');
    const status = document.getElementById('modalSaveStatus');
    const val = id => { const el = document.getElementById(id); return el ? el.value : undefined; };
    const payload = { id: currentId };
    const etapa = window.__overrideEtapa || val('editEtapa'); if (etapa !== undefined) payload.etapa = etapa;
    const asign = val('editAsignado'); if (asign !== undefined) payload.asignado_a = asign;
    const notas = val('editNotas'); if (notas !== undefined) payload.notas_humanas = notas;
    const mallas = val('editMallas'); if (mallas !== undefined) payload.mallas_estado = mallas;
    const vrec = val('editVideoRec'); if (vrec !== undefined) payload.video_recibido = Number(vrec);
    const vvia = val('editVideoViable'); if (vvia !== undefined) payload.video_viable = vvia;
    const vnot = val('editVideoNotas'); if (vnot !== undefined) payload.video_notas = vnot;
    const obs = val('editObsContacto'); if (obs !== undefined) payload.observaciones_contacto = obs;
    const entr = val('editEntrevista'); if (entr !== undefined) payload.entrevista_notas = entr;
    const resc = val('editRescatista'); if (resc !== undefined) payload.rescatista_asignado = resc;
    const nh = val('editNotaHist'); if (nh) payload.nota_historial = nh;
    if (window.__motivoRechazo) payload.motivo_rechazo = window.__motivoRechazo;

    btn.disabled = true; btn.textContent = 'Guardando...'; status.textContent = '';
    try {
      const res = await fetch('/api/admin/update-solicitud', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
      if (res.ok) { await loadData(); closeModal(); }
      else { status.textContent = '❌ Error al guardar'; }
    } catch (err) { status.textContent = '❌ Error de conexión'; }
    finally { btn.disabled = false; btn.textContent = 'Guardar y cerrar'; window.__overrideEtapa = null; window.__motivoRechazo = null; }
  };

  document.getElementById('btnRefresh').onclick = loadData;
  document.getElementById('searchInput').oninput = renderTable;
  document.getElementById('filterEtapa').onchange = renderTable;
  document.getElementById('filterReco').onchange = renderTable;
  document.getElementById('filterMine').onchange = renderTable;
  document.getElementById('btnLogout').onclick = () => {
    document.cookie = "session=; Path=/; Expires=Thu, 01 Jan 1970 00:00:01 GMT;";
    window.location.href = '/intranet/login';
  };

  (async () => { await loadMe(); await loadData(); })();
</script>
</Layout>
