        <div class="grid md:grid-cols-2 gap-5">
          <div><label class="text-xs font-bold text-gray-500 uppercase mb-1 block">Mallas de seguridad</label><select id="editMallas" class="w-full rounded-xl border-gray-200 text-sm focus:ring-blue-500 focus:border-blue-500">${selOpt('sin_definir','Sin definir',s.mallas_estado)}${selOpt('acepta_instalar','Aceptó instalar',s.mallas_estado)}${selOpt('ya_instaladas','Ya instaladas',s.mallas_estado)}${selOpt('no_acepta','No acepta',s.mallas_estado)}</select></div>
          <div class="grid grid-cols-2 gap-3"><div><label class="text-xs font-bold text-gray-500 uppercase mb-1 block">¿Envió video?</label><select id="editVideoRec" class="w-full rounded-xl border-gray-200 text-sm focus:ring-blue-500 focus:border-blue-500">${selOpt('0','No', String(s.video_recibido||0))}${selOpt('1','Sí', String(s.video_recibido||0))}</select></div><div><label class="text-xs font-bold text-gray-500 uppercase mb-1 block">¿Video viable?</label><select id="editVideoViable" class="w-full rounded-xl border-gray-200 text-sm focus:ring-blue-500 focus:border-blue-500">${selOpt('sin_revisar','Sin revisar',s.video_viable)}${selOpt('si','Sí, viable',s.video_viable)}${selOpt('no','No viable',s.video_viable)}</select></div></div>
        </div>
        <div class="mt-4"><label class="text-xs font-bold text-gray-500 uppercase mb-1 block">Notas del video</label><input id="editVideoNotas" type="text" value="${esc(s.video_notas || '')}" placeholder="Observaciones del video del hogar..." class="w-full rounded-xl border-gray-200 text-sm focus:ring-blue-500 focus:border-blue-500" /></div>
        <div class="mt-4"><label class="text-xs font-bold text-gray-500 uppercase mb-1 block">Mi concepto (Federico)</label><textarea id="editObsContacto" rows="3" class="w-full rounded-xl border-gray-200 text-sm focus:ring-blue-500 focus:border-blue-500" placeholder="Concepto tras revisar video, mallas y el contacto...">${esc(s.observaciones_contacto || '')}</textarea></div>
      </div>`;
    } else {
      conceptoBlock = `<div class="bg-green-50/40 rounded-2xl border border-green-200 p-6 mb-6"><h3 class="text-sm font-bold text-green-800 uppercase tracking-wide mb-3">✓ Mi concepto <span class="text-green-600 font-normal normal-case">— superado</span></h3>${roRow('Mallas de seguridad', s.mallas_estado)}${roRow('¿Envió video?', fmtBool(s.video_recibido))}${roRow('¿Video viable?', s.video_viable)}${roRow('Notas del video', s.video_notas)}${roRow('Concepto (Federico)', s.observaciones_contacto)}</div>`;
    }

    // ── Bloque «Concepto de Laura» (entrevista) ──
    let entrevistaBlock;
    if (curOrder < ORDER.entrevista) {
      entrevistaBlock = `<div class="bg-gray-50 rounded-2xl border border-dashed border-gray-200 p-5 mb-6 text-sm text-gray-400">🔒 Concepto de Laura — se habilita cuando se supere tu concepto inicial.</div>`;
    } else if (cur === 'entrevista') {
