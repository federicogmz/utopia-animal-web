        <h3 class="text-sm font-bold text-amber-800 uppercase tracking-wide mb-1">🎙️ Concepto de Laura <span class="text-amber-600 font-normal normal-case">— en curso</span></h3>
        <p class="text-xs text-gray-500 mb-4">Entrevista a fondo y, de ser viable, escalar a rescatista.</p>
        <div><label class="text-xs font-bold text-gray-500 uppercase mb-1 block">Concepto de la entrevista (Laura)</label><textarea id="editEntrevista" rows="3" class="w-full rounded-xl border-gray-200 text-sm focus:ring-amber-500 focus:border-amber-500" placeholder="Conclusiones de la entrevista final...">${esc(s.entrevista_notas || '')}</textarea></div>
        <div class="mt-4"><label class="text-xs font-bold text-gray-500 uppercase mb-1 block">Rescatista asignado (para la entrega)</label><input id="editRescatista" type="text" value="${esc(s.rescatista_asignado || '')}" placeholder="Nombre del rescatista que coordina la entrega" class="w-full rounded-xl border-gray-200 text-sm focus:ring-amber-500 focus:border-amber-500" /></div>
      </div>`;
    } else {
      entrevistaBlock = `<div class="bg-green-50/40 rounded-2xl border border-green-200 p-6 mb-6"><h3 class="text-sm font-bold text-green-800 uppercase tracking-wide mb-3">✓ Concepto de Laura <span class="text-green-600 font-normal normal-case">— superado</span></h3>${roRow('Concepto (Laura)', s.entrevista_notas)}${roRow('Rescatista asignado', s.rescatista_asignado)}</div>`;
    }

    const timeline = `<div id="timelineBox" class="bg-white rounded-2xl border border-gray-200 p-6 mb-6"><h3 class="text-sm font-bold text-gray-900 uppercase tracking-wide mb-4">🕘 Historial de cambios</h3><p class="text-sm text-gray-400" id="timelineContent">Cargando…</p></div>`;

    const personal = section('Datos personales', dl(row('Nombre', s.nombre_completo) + row('Cédula', s.cedula) + row('Edad', s.edad) + row('Ocupación', s.ocupacion) + row('Teléfono', s.telefono) + row('Correo', s.correo) + row('Dirección', s.direccion) + row('Ciudad', s.ciudad) + row('Barrio', s.barrio) + row('Estrato', s.estrato)));
    const vivienda = section('Vivienda', dl(row('Tipo de vivienda', s.tipo_vivienda) + row('Situación habitacional', s.situacion_habitacional) + boolRow('Mallas de seguridad (declarado)', s.mallas_seguridad)));
    const redes = section('Redes y referencias', dl(row('Instagram', s.instagram) + row('Facebook', s.facebook) + row('Cómo nos conoció', s.como_nos_conociste) + row('Familiar', s.familiar_nombre) + row('Tel. familiar', s.familiar_telefono) + row('Referencia', s.referencia_nombre) + row('Tel. referencia', s.referencia_telefono)));
    const motivacion = section('Motivación', `${longField('¿Por qué quiere adoptar?', s.por_que_adoptar)}<div class="mt-4">${dl(row('Género preferido', s.genero_preferido) + row('Edad del gato', s.edad_estimada_gatito) + row('Responsable de gastos', s.responsable_gastos) + row('Cuidador principal', s.cuidador_principal))}</div>`);
