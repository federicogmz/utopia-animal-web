---
import Layout from './Layout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, date, category, tags, imageAlt } = post.data;

// Posts relacionados (cross-linking interno): misma categoría pesa más,
// luego tags compartidos; desempata por fecha. Máximo 3.
const allPosts = await getCollection('blog');
const related = allPosts
  .filter((p) => p.slug !== post.slug)
  .map((p) => {
    let score = p.data.category === category ? 3 : 0;
    score += (p.data.tags || []).filter((t) => (tags || []).includes(t)).length;
    return { p, score };
  })
  .sort((a, b) => b.score - a.score || +b.p.data.date - +a.p.data.date)
  .slice(0, 3)
  .map((x) => x.p);

const formattedDate = date.toLocaleDateString('es-CO', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const categoryColors: Record<string, string> = {
  'Adopción': 'bg-elim-100 text-elim-800',
  'Salud y Nutrición': 'bg-blue-100 text-blue-800',
  'Bienestar': 'bg-elim-100 text-elim-800',
  'Comportamiento': 'bg-purple-100 text-purple-800',
  'Cuidado Responsable': 'bg-amber-100 text-amber-800',
  'Veterinaria': 'bg-utopia-100 text-utopia-800',
};

const isVetCategory = category === 'Veterinaria' || category === 'Salud y Nutrición';

const badgeClass = categoryColors[category] ?? 'bg-gray-100 text-gray-700';
---

<Layout title={title} description={description}>
  <article class="max-w-3xl mx-auto px-4 sm:px-6 py-16">

    <!-- Back link -->
    <a
      href="/blog"
      class="inline-flex items-center gap-2 text-elim-700 hover:text-elim-900 font-medium mb-8 group transition-colors"
    >
      <svg class="w-4 h-4 transition-transform group-hover:-translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
      Volver al Blog
    </a>

    <!-- Category badge -->
    <span class={`inline-block text-xs font-semibold uppercase tracking-wider px-3 py-1 rounded-full mb-4 ${badgeClass}`}>
      {category}
    </span>

    <!-- Title -->
    <h1 class="text-3xl sm:text-4xl font-extrabold text-elim-950 dark:text-elim-100 leading-tight mb-4">
      {title}
    </h1>

    <!-- Description -->
    <p class="text-lg text-gray-600 mb-6 leading-relaxed">{description}</p>

    <!-- Meta -->
    <div class="flex flex-wrap items-center gap-4 pb-6 border-b border-elim-100 mb-8 text-sm text-gray-500">
      <div class="flex items-center gap-2">
        <svg class="w-4 h-4 text-elim-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
        </svg>
        <time datetime={date.toISOString()}>{formattedDate}</time>
      </div>
      <div class="flex items-center gap-2">
        <svg class="w-4 h-4 text-elim-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
        </svg>
        Refugio Animal Elim
      </div>
    </div>

    <!-- Content -->
    <div class="prose prose-lg prose-elim max-w-none
      prose-headings:text-elim-900 dark:prose-headings:text-elim-200 prose-headings:font-bold
      prose-a:text-elim-700 dark:prose-a:text-elim-400 prose-a:font-medium prose-a:no-underline hover:prose-a:underline
      prose-strong:text-elim-900 dark:prose-strong:text-elim-200
      prose-ul:text-gray-700 dark:prose-ul:text-gray-300 prose-li:marker:text-elim-500
      prose-blockquote:border-elim-400 prose-blockquote:text-gray-600 dark:prose-blockquote:text-gray-300
      prose-img:rounded-xl prose-img:shadow-md">
      <slot />
    </div>

    <!-- Tags -->
    {tags && tags.length > 0 && (
      <div class="mt-10 pt-6 border-t border-elim-100">
        <p class="text-sm font-semibold text-gray-500 mb-3">Etiquetas:</p>
        <div class="flex flex-wrap gap-2">
          {tags.map((tag) => (
            <span class="px-3 py-1 text-xs bg-elim-50 text-elim-700 border border-elim-200 rounded-full font-medium">
              #{tag}
            </span>
          ))}
        </div>
      </div>
    )}

    <!-- Posts relacionados (cross-linking interno) -->
    {related.length > 0 && (
      <section class="mt-12 pt-8 border-t border-elim-100">
        <h2 class="text-xl font-bold text-elim-900 dark:text-elim-200 mb-5">Sigue leyendo</h2>
        <div class="grid sm:grid-cols-3 gap-4">
          {related.map((p) => (
            <a
              href={`/blog/${p.slug}`}
              class="block bg-white dark:bg-gray-900 border border-elim-100 rounded-xl p-4 hover:shadow-md hover:border-elim-300 transition-all group"
            >
              <span class="text-[11px] font-semibold uppercase tracking-wider text-elim-600 dark:text-elim-400">{p.data.category}</span>
              <p class="mt-1.5 font-semibold text-sm text-gray-900 dark:text-gray-100 leading-snug group-hover:text-elim-700 dark:group-hover:text-elim-300 transition-colors">
                {p.data.title}
              </p>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- CTA -->
    {isVetCategory ? (
      <div class="mt-12 bg-utopia-50 border border-utopia-200 rounded-2xl p-6 flex flex-col sm:flex-row items-center gap-4">
        <div class="text-4xl">🏥</div>
        <div class="text-center sm:text-left">
          <p class="font-bold text-utopia-900">¿Listo para agendar?</p>
          <p class="text-sm text-gray-600 mt-1">
            Utopía Animal Vet en Guayabal. Consultas, vacunas, esterilización, urgencias y más.
          </p>
        </div>
        <a
          href="https://api.whatsapp.com/send?phone=573215308188&text=Hola,%20quiero%20agendar%20una%20cita%20en%20Utop%C3%ADa%20Animal%20Vet"
          target="_blank" rel="noopener"
          class="shrink-0 bg-green-500 hover:bg-green-600 text-white font-semibold px-5 py-2.5 rounded-xl transition-colors text-sm whitespace-nowrap"
        >
          💬 Agendar por WhatsApp
        </a>
      </div>
    ) : (
      <div class="mt-12 bg-elim-50 border border-elim-200 rounded-2xl p-6 flex flex-col sm:flex-row items-center gap-4">
        <div class="text-4xl">🐾</div>
        <div class="text-center sm:text-left">
          <p class="font-bold text-elim-900">¿Quieres apoyar a los gatos de Medellín?</p>
          <p class="text-sm text-gray-600 mt-1">
            Con tu apoyo financiamos jornadas de esterilización, atención médica y bienestar animal.
          </p>
        </div>
        <a
          href="/apoya"
          class="shrink-0 bg-elim-700 hover:bg-elim-800 text-white font-semibold px-5 py-2.5 rounded-xl transition-colors text-sm"
        >
          Apoya la causa
        </a>
      </div>
    )}

  </article>
</Layout>
