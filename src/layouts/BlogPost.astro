---
import Layout from './Layout.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, date, category, tags, imageAlt } = post.data;

const formattedDate = date.toLocaleDateString('es-CO', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const categoryColors: Record<string, string> = {
  'Salud y Nutrición': 'bg-blue-100 text-blue-800',
  'Bienestar': 'bg-elim-100 text-elim-800',
  'Comportamiento': 'bg-purple-100 text-purple-800',
  'Cuidado Responsable': 'bg-amber-100 text-amber-800',
};

const badgeClass = categoryColors[category] ?? 'bg-gray-100 text-gray-700';
---

<Layout title={title} description={description}>
  <article class="max-w-3xl mx-auto px-4 sm:px-6 py-16">

    <!-- Back link -->
    <a
      href="/blog"
      class="inline-flex items-center gap-2 text-elim-700 hover:text-elim-900 font-medium mb-8 group transition-colors"
    >
      <svg class="w-4 h-4 transition-transform group-hover:-translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
      Volver al Blog
    </a>

    <!-- Category badge -->
    <span class={`inline-block text-xs font-semibold uppercase tracking-wider px-3 py-1 rounded-full mb-4 ${badgeClass}`}>
      {category}
    </span>

    <!-- Title -->
    <h1 class="text-3xl sm:text-4xl font-extrabold text-elim-950 leading-tight mb-4">
      {title}
    </h1>

    <!-- Description -->
    <p class="text-lg text-gray-600 mb-6 leading-relaxed">{description}</p>

    <!-- Meta -->
    <div class="flex flex-wrap items-center gap-4 pb-6 border-b border-elim-100 mb-8 text-sm text-gray-500">
      <div class="flex items-center gap-2">
        <svg class="w-4 h-4 text-elim-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
        </svg>
        <time datetime={date.toISOString()}>{formattedDate}</time>
      </div>
      <div class="flex items-center gap-2">
        <svg class="w-4 h-4 text-elim-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
        </svg>
        Refugio Animal Elim
      </div>
    </div>

    <!-- Content -->
    <div class="prose prose-lg prose-elim max-w-none
      prose-headings:text-elim-900 prose-headings:font-bold
      prose-a:text-elim-700 prose-a:font-medium prose-a:no-underline hover:prose-a:underline
      prose-strong:text-elim-900
      prose-ul:text-gray-700 prose-li:marker:text-elim-500
      prose-blockquote:border-elim-400 prose-blockquote:text-gray-600
      prose-img:rounded-xl prose-img:shadow-md">
      <slot />
    </div>

    <!-- Tags -->
    {tags && tags.length > 0 && (
      <div class="mt-10 pt-6 border-t border-elim-100">
        <p class="text-sm font-semibold text-gray-500 mb-3">Etiquetas:</p>
        <div class="flex flex-wrap gap-2">
          {tags.map((tag) => (
            <span class="px-3 py-1 text-xs bg-elim-50 text-elim-700 border border-elim-200 rounded-full font-medium">
              #{tag}
            </span>
          ))}
        </div>
      </div>
    )}

    <!-- CTA -->
    <div class="mt-12 bg-elim-50 border border-elim-200 rounded-2xl p-6 flex flex-col sm:flex-row items-center gap-4">
      <div class="text-4xl">🐾</div>
      <div class="text-center sm:text-left">
        <p class="font-bold text-elim-900">¿Quieres apoyar a los gatos de Medellín?</p>
        <p class="text-sm text-gray-600 mt-1">
          Con tu apoyo financiamos jornadas de esterilización, atención médica y bienestar animal.
        </p>
      </div>
      <a
        href="/apoya"
        class="shrink-0 bg-elim-700 hover:bg-elim-800 text-white font-semibold px-5 py-2.5 rounded-xl transition-colors text-sm"
      >
        Apoya la causa
      </a>
    </div>

  </article>
</Layout>
