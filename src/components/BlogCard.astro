---
interface Props {
  title: string;
  description: string;
  date: Date;
  category: string;
  slug: string;
}

const { title, description, date, category, slug } = Astro.props;

const formattedDate = date.toLocaleDateString('es-CO', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});

const categoryColors: Record<string, string> = {
  'Salud y Nutrición': 'bg-blue-100 text-blue-700',
  'Bienestar': 'bg-elim-100 text-elim-700',
  'Comportamiento': 'bg-purple-100 text-purple-700',
  'Cuidado Responsable': 'bg-amber-100 text-amber-700',
};

const badgeClass = categoryColors[category] ?? 'bg-gray-100 text-gray-600';

const categoryEmojis: Record<string, string> = {
  'Salud y Nutrición': '🥗',
  'Bienestar': '🌿',
  'Comportamiento': '🧠',
  'Cuidado Responsable': '💛',
};

const emoji = categoryEmojis[category] ?? '🐱';
---

<a
  href={`/blog/${slug}`}
  class="group bg-white rounded-2xl border border-gray-100 shadow-sm hover:shadow-md transition-all hover:-translate-y-0.5 flex flex-col overflow-hidden"
>
  <!-- Card header with color accent -->
  <div class="h-3 bg-elim-600 group-hover:bg-elim-500 transition-colors"></div>

  <div class="p-6 flex flex-col flex-1">
    <!-- Category -->
    <div class="flex items-center gap-2 mb-3">
      <span class="text-base">{emoji}</span>
      <span class={`text-xs font-semibold px-2.5 py-0.5 rounded-full ${badgeClass}`}>
        {category}
      </span>
    </div>

    <!-- Title -->
    <h3 class="font-bold text-gray-900 text-lg leading-snug mb-2 group-hover:text-elim-700 transition-colors line-clamp-2">
      {title}
    </h3>

    <!-- Description -->
    <p class="text-gray-500 text-sm leading-relaxed line-clamp-3 flex-1">
      {description}
    </p>

    <!-- Footer -->
    <div class="mt-4 pt-4 border-t border-gray-100 flex items-center justify-between">
      <time class="text-xs text-gray-400">{formattedDate}</time>
      <span class="text-xs font-semibold text-elim-600 group-hover:text-elim-800 flex items-center gap-1 transition-colors">
        Leer artículo
        <svg class="w-3 h-3 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
      </span>
    </div>
  </div>
</a>
